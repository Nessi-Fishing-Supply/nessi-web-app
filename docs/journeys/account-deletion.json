{
  "slug": "account-deletion",
  "domain": "account",
  "title": "Account Deletion (Full Cascade)",
  "persona": "account",
  "description": "Full account deletion cascade: shop ownership gate, storage cleanup (avatars, listing photos, hero banners), slug cleanup, auth user deletion with FK cascades and DB triggers.",
  "relatedIssues": [],
  "flows": [
    {
      "id": "delete-account",
      "title": "Delete Account Cascade",
      "trigger": "User clicks Delete Account in danger zone",
      "steps": [
        {
          "id": "click-delete",
          "title": "Click Delete Account",
          "action": "click",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "call-api",
          "title": "Delete Account",
          "method": "DELETE",
          "layer": "server",
          "status": "built",
          "route": "/api/auth/delete-account"
        },
        {
          "id": "check-shops",
          "title": "Check Shop Ownership",
          "layer": "server",
          "status": "built",
          "tooltip": "Check if user owns active shops",
          "errorCases": [
            {
              "condition": "Owns active shops",
              "result": "409: Must transfer or delete shops first — show shop names as links",
              "httpStatus": 409
            }
          ]
        },
        {
          "id": "delete-member-avatar",
          "title": "Delete Member Avatar",
          "layer": "server",
          "status": "built",
          "tooltip": "Delete from profile-assets bucket"
        },
        {
          "id": "delete-listing-photos",
          "title": "Delete Listing Photos",
          "layer": "server",
          "status": "built",
          "tooltip": "Delete from listing-images bucket"
        },
        {
          "id": "delete-shop-avatars",
          "title": "Delete Shop Avatars",
          "layer": "server",
          "status": "built",
          "tooltip": "Delete from profile-assets bucket"
        },
        {
          "id": "delete-shop-banners",
          "title": "Delete Shop Banners",
          "layer": "server",
          "status": "built",
          "tooltip": "Delete hero banners from profile-assets bucket"
        },
        {
          "id": "delete-shop-listing-photos",
          "title": "Delete Shop Photos",
          "layer": "server",
          "status": "built",
          "tooltip": "Delete shop listing photos from listing-images bucket"
        },
        {
          "id": "delete-member-slug",
          "title": "Delete Member Slug",
          "layer": "database",
          "status": "built",
          "tooltip": "Delete member slug from slugs table"
        },
        {
          "id": "delete-auth-user",
          "title": "Delete Auth User",
          "layer": "server",
          "status": "built",
          "tooltip": "auth.admin.deleteUser() — triggers CASCADE"
        },
        {
          "id": "cascade-members",
          "title": "Cascade Delete Members",
          "layer": "database",
          "status": "built",
          "tooltip": "CASCADE: members row deleted"
        },
        {
          "id": "trigger-cleanup",
          "title": "Run Deletion Trigger",
          "layer": "database",
          "status": "built",
          "tooltip": "BEFORE DELETE trigger: handle_member_deletion() — release member slug + owned shop slugs"
        },
        {
          "id": "cascade-fk",
          "title": "Cascade FK Deletes",
          "layer": "database",
          "status": "built",
          "tooltip": "CASCADE: cart items, recently viewed, shop memberships deleted"
        },
        {
          "id": "clear-session",
          "title": "Clear Session",
          "layer": "server",
          "status": "built"
        },
        {
          "id": "redirect-home",
          "title": "Redirect Home",
          "action": "navigate",
          "layer": "client",
          "status": "built",
          "tooltip": "Redirect to /"
        }
      ],
      "branches": [
        {
          "afterStep": "check-shops",
          "condition": "Owns active shops?",
          "paths": [
            {
              "label": "Yes",
              "detail": "409 — must resolve first",
              "goTo": "END"
            },
            {
              "label": "No",
              "goTo": "delete-member-avatar"
            }
          ]
        }
      ]
    }
  ]
}
