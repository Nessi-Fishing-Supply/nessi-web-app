{
  "slug": "shop-roles",
  "domain": "shops",
  "title": "Shop Roles & Permissions",
  "persona": "shop-owner",
  "description": "Roles & Permissions page showing system role cards (Owner, Manager, Contributor) with permission matrix. Custom roles gated behind premium plan.",
  "relatedIssues": [],
  "flows": [
    {
      "id": "view-roles",
      "title": "View Roles & Permissions Page",
      "trigger": "User navigates to /dashboard/shop/roles",
      "steps": [
        {
          "id": "navigate-roles",
          "title": "Open Roles Page",
          "action": "navigate",
          "layer": "client",
          "status": "built",
          "route": "/dashboard/shop/roles"
        },
        {
          "id": "route-guard",
          "title": "Check User Role",
          "layer": "client",
          "status": "built",
          "tooltip": "ShopRouteGuard checks user role. Contributors redirected to /dashboard."
        },
        {
          "id": "show-system-roles",
          "title": "Show System Roles",
          "layer": "client",
          "status": "built",
          "tooltip": "System Roles section with RoleCards"
        },
        {
          "id": "owner-role",
          "title": "Owner Role Card",
          "layer": "client",
          "status": "built",
          "tooltip": "All 6 domains at 'full' permission level"
        },
        {
          "id": "manager-role",
          "title": "Manager Role Card",
          "layer": "client",
          "status": "built",
          "tooltip": "listings/pricing/orders/messaging 'full', shop_settings 'view', members 'none'"
        },
        {
          "id": "contributor-role",
          "title": "Contributor Role Card",
          "layer": "client",
          "status": "built",
          "tooltip": "listings 'full' only"
        },
        {
          "id": "permission-matrix",
          "title": "Show Permission Grid",
          "layer": "client",
          "status": "built",
          "tooltip": "Each card shows PermissionMatrix grid"
        }
      ],
      "branches": [
        {
          "afterStep": "route-guard",
          "condition": "User's role?",
          "paths": [
            {
              "label": "Owner/Manager",
              "goTo": "show-system-roles"
            },
            {
              "label": "Contributor",
              "detail": "Redirect to /dashboard",
              "goTo": "END"
            }
          ]
        }
      ]
    },
    {
      "id": "custom-roles",
      "title": "Custom Roles (Premium Gate)",
      "trigger": "Owner clicks 'Add Custom Role'",
      "steps": [
        {
          "id": "click-add-custom",
          "title": "Click Add Custom Role",
          "action": "click",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "upsell-modal",
          "title": "Show Upsell Modal",
          "action": "open",
          "layer": "client",
          "status": "planned",
          "tooltip": "CustomRoleUpsellModal — premium plan gate (not yet available)"
        }
      ]
    }
  ]
}
