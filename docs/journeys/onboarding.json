{
  "slug": "onboarding",
  "domain": "account",
  "title": "Onboarding Wizard (Buyer vs Seller Path)",
  "persona": "onboarding",
  "description": "Branching wizard after first signup. Buyer path (4 steps) vs Seller path (5 steps). Includes post-onboarding seller opt-in for users who initially chose buyer.",
  "relatedIssues": [],
  "flows": [
    {
      "id": "buyer-path",
      "title": "Onboarding — Buyer Path (4 Steps)",
      "trigger": "New user signs up, verifies OTP, and visits /onboarding",
      "steps": [
        {
          "id": "banner-appears",
          "title": "Show Onboarding Banner",
          "layer": "client",
          "status": "built",
          "tooltip": "Onboarding banner appears after signup"
        },
        {
          "id": "visit-onboarding",
          "title": "Visit Onboarding Page",
          "action": "navigate",
          "layer": "client",
          "status": "built",
          "route": "/onboarding"
        },
        {
          "id": "step1-display-name",
          "title": "Set Display Name",
          "action": "type",
          "layer": "client",
          "status": "built",
          "tooltip": "Step 1: Display Name + Avatar"
        },
        {
          "id": "step2-intent",
          "title": "Choose Intent",
          "action": "select",
          "layer": "client",
          "status": "built",
          "tooltip": "Step 2: How will you use Nessi?"
        },
        {
          "id": "step3-fishing-identity",
          "title": "Fishing Identity",
          "action": "select",
          "layer": "client",
          "status": "built",
          "tooltip": "Step 3: Fishing Identity (optional)"
        },
        {
          "id": "step4-bio",
          "title": "Write Bio",
          "action": "type",
          "layer": "client",
          "status": "built",
          "tooltip": "Step 4: Bio (280 chars)"
        },
        {
          "id": "complete-onboarding",
          "title": "Complete Onboarding",
          "layer": "server",
          "status": "built",
          "tooltip": "completeOnboarding() called"
        },
        {
          "id": "redirect-dashboard",
          "title": "Go to Dashboard",
          "action": "navigate",
          "layer": "client",
          "status": "built",
          "tooltip": "Redirect to /dashboard"
        }
      ],
      "branches": [
        {
          "afterStep": "step2-intent",
          "condition": "Intent choice?",
          "paths": [
            {
              "label": "Buyer",
              "goTo": "step3-fishing-identity"
            },
            {
              "label": "Seller/Both",
              "detail": "See seller-path flow",
              "goTo": "END"
            }
          ]
        }
      ]
    },
    {
      "id": "seller-path",
      "title": "Onboarding — Seller Path (5 Steps)",
      "trigger": "User selects Seller or Both intent in Step 2",
      "steps": [
        {
          "id": "step3-fishing-identity-seller",
          "title": "Fishing Identity",
          "action": "select",
          "layer": "client",
          "status": "built",
          "tooltip": "Step 3: Fishing Identity (optional)"
        },
        {
          "id": "step4-seller-type",
          "title": "Choose Seller Type",
          "action": "select",
          "layer": "client",
          "status": "built",
          "tooltip": "Step 4: Free profile or shop"
        },
        {
          "id": "step5-bio",
          "title": "Write Bio",
          "action": "type",
          "layer": "client",
          "status": "built",
          "tooltip": "Step 5: Bio (280 chars)"
        },
        {
          "id": "complete-onboarding-seller",
          "title": "Complete Onboarding",
          "layer": "server",
          "status": "built",
          "tooltip": "completeOnboarding() called"
        },
        {
          "id": "redirect-dashboard-seller",
          "title": "Go to Dashboard",
          "action": "navigate",
          "layer": "client",
          "status": "built",
          "tooltip": "Redirect to /dashboard"
        }
      ],
      "branches": [
        {
          "afterStep": "step4-seller-type",
          "condition": "Seller type?",
          "paths": [
            {
              "label": "Free Profile",
              "goTo": "step5-bio"
            },
            {
              "label": "Shop",
              "goTo": "step5-bio"
            }
          ]
        }
      ]
    },
    {
      "id": "post-onboarding-seller-optin",
      "title": "Post-Onboarding Seller Opt-In",
      "trigger": "Buyer-onboarded user clicks 'Start Selling' CTA in dashboard",
      "steps": [
        {
          "id": "show-cta",
          "title": "Show Selling CTA",
          "layer": "client",
          "status": "built",
          "tooltip": "Dashboard shows 'Start Selling' CTA"
        },
        {
          "id": "click-cta",
          "title": "Click Start Selling",
          "action": "click",
          "layer": "client",
          "status": "built",
          "tooltip": "SellerOnboardingModal opens"
        },
        {
          "id": "choose-method",
          "title": "Choose Selling Method",
          "action": "select",
          "layer": "client",
          "status": "built",
          "tooltip": "Free profile or Create a shop"
        }
      ],
      "branches": [
        {
          "afterStep": "choose-method",
          "condition": "Selling method?",
          "paths": [
            {
              "label": "Free Profile",
              "detail": "toggleSeller(true) → is_seller = true",
              "goTo": "END"
            },
            {
              "label": "Create Shop",
              "detail": "Redirect to /dashboard/shop/create",
              "goTo": "END"
            }
          ]
        }
      ]
    }
  ]
}
