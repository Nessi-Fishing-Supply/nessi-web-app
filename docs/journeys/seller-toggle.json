{
  "slug": "seller-toggle",
  "domain": "account",
  "title": "Seller Toggle (On/Off)",
  "persona": "seller",
  "description": "User toggles seller status on or off from account settings. Toggling off requires no active listings or orders, and hides all listings from search.",
  "relatedIssues": [],
  "flows": [
    {
      "id": "toggle-on",
      "title": "Enable Seller Status",
      "trigger": "Non-seller user toggles seller ON in /dashboard/account → Seller Settings",
      "steps": [
        {
          "id": "click-toggle-on",
          "title": "Toggle Seller On",
          "action": "toggle",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "post-toggle-on",
          "title": "Enable Seller Flag",
          "method": "POST",
          "layer": "server",
          "status": "built",
          "route": "/api/members/toggle-seller",
          "tooltip": "is_seller=true"
        },
        {
          "id": "show-seller-features",
          "title": "Show Seller Features",
          "layer": "client",
          "status": "built",
          "tooltip": "Dashboard shows seller features"
        }
      ]
    },
    {
      "id": "toggle-off",
      "title": "Disable Seller Status",
      "trigger": "Seller user clicks toggle OFF",
      "steps": [
        {
          "id": "click-toggle-off",
          "title": "Toggle Seller Off",
          "action": "toggle",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "check-preconditions",
          "title": "Check Preconditions",
          "method": "GET",
          "layer": "server",
          "status": "built",
          "route": "/api/members/seller-preconditions"
        },
        {
          "id": "show-warning",
          "title": "Show Warning",
          "layer": "client",
          "status": "built",
          "tooltip": "X active listings, Y orders — must resolve first"
        },
        {
          "id": "post-toggle-off",
          "title": "Disable Seller Flag",
          "method": "POST",
          "layer": "server",
          "status": "built",
          "route": "/api/members/toggle-seller",
          "tooltip": "is_seller=false"
        },
        {
          "id": "hide-listings",
          "title": "Hide All Listings",
          "layer": "database",
          "status": "built",
          "tooltip": "All listings hidden from search"
        },
        {
          "id": "hide-seller-features",
          "title": "Hide Seller Features",
          "layer": "client",
          "status": "built",
          "tooltip": "Seller features hidden in dashboard"
        }
      ],
      "branches": [
        {
          "afterStep": "check-preconditions",
          "condition": "Has active items?",
          "paths": [
            {
              "label": "Yes",
              "detail": "Must resolve active listings/orders first",
              "goTo": "show-warning"
            },
            {
              "label": "No",
              "goTo": "post-toggle-off"
            }
          ]
        }
      ]
    }
  ]
}
