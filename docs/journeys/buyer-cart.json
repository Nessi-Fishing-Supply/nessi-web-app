{
  "slug": "buyer-cart",
  "domain": "cart",
  "title": "Authenticated Cart (DB-Backed)",
  "persona": "buyer",
  "description": "Authenticated buyer adds items to DB-backed cart with price snapshots, 30-day expiry, seller grouping, and pre-checkout validation. Block enforcement prevents adding items from sellers who have blocked the buyer.",
  "relatedIssues": [324],
  "flows": [
    {
      "id": "add-to-cart",
      "title": "Add Item to Cart",
      "trigger": "Buyer clicks 'Add to Cart' on listing detail page",
      "steps": [
        {
          "id": "click-add",
          "title": "Click Add to Cart",
          "action": "click",
          "layer": "client",
          "status": "built",
          "errorCases": [
            {
              "condition": "Own listing",
              "result": "Button disabled"
            },
            {
              "condition": "Already in cart",
              "result": "Button shows 'In Cart'"
            },
            {
              "condition": "Cart has 25 items",
              "result": "Toast: cart full"
            }
          ]
        },
        {
          "id": "post-cart",
          "title": "Add to Cart",
          "method": "POST",
          "layer": "server",
          "status": "built",
          "route": "/api/cart",
          "codeRef": "src/app/api/cart/route.ts",
          "tooltip": "Send listingId + priceCents. Server checks: listing exists + active, block check (isBlockedByServer), not own listing, no duplicate, cart cap.",
          "errorCases": [
            {
              "condition": "Seller has blocked the buyer",
              "result": "Returns 403 'You cannot purchase this listing'",
              "httpStatus": 403
            },
            {
              "condition": "Listing not found or inactive",
              "result": "Returns 404",
              "httpStatus": 404
            },
            {
              "condition": "Own listing",
              "result": "Returns 403",
              "httpStatus": 403
            },
            {
              "condition": "Already in cart",
              "result": "Returns 409",
              "httpStatus": 409
            },
            {
              "condition": "Cart full (25 items)",
              "result": "Returns 422",
              "httpStatus": 422
            }
          ]
        },
        {
          "id": "price-snapshot",
          "title": "Save Price Snapshot",
          "layer": "database",
          "status": "built",
          "tooltip": "Price snapshot saved as price_at_add"
        },
        {
          "id": "set-expiry",
          "title": "Set 30-Day Expiry",
          "layer": "database",
          "status": "built"
        },
        {
          "id": "optimistic-update",
          "title": "Update Cache",
          "layer": "client",
          "status": "built",
          "tooltip": "Optimistic cache update"
        },
        {
          "id": "show-toast",
          "title": "Show Added Toast",
          "layer": "client",
          "status": "built",
          "tooltip": "Toast: Added to cart"
        }
      ]
    },
    {
      "id": "view-cart",
      "title": "View Cart",
      "trigger": "Buyer navigates to /cart",
      "steps": [
        {
          "id": "fetch-cart",
          "title": "Fetch Cart Items",
          "method": "GET",
          "layer": "server",
          "status": "built",
          "route": "/api/cart",
          "tooltip": "Returns cart items joined with listing data"
        },
        {
          "id": "group-by-seller",
          "title": "Group by Seller",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "show-item-states",
          "title": "Show Item States",
          "layer": "client",
          "status": "built",
          "tooltip": "States: valid, price changed (old vs new), removed/sold (warning)"
        },
        {
          "id": "cart-actions",
          "title": "Show Cart Actions",
          "layer": "client",
          "status": "built",
          "tooltip": "Actions: remove item, clear all, refresh expiry"
        }
      ],
      "connections": [
        {
          "from": "cart-actions",
          "to": "remove-item",
          "label": "Remove"
        },
        {
          "from": "cart-actions",
          "to": "clear-all",
          "label": "Clear"
        },
        {
          "from": "cart-actions",
          "to": "refresh-expiry",
          "label": "Refresh"
        }
      ]
    },
    {
      "id": "cart-actions",
      "title": "Cart Item Actions",
      "trigger": "Buyer interacts with cart items",
      "steps": [
        {
          "id": "remove-item",
          "title": "Remove Item",
          "method": "DELETE",
          "layer": "server",
          "status": "built",
          "route": "/api/cart/[id]"
        },
        {
          "id": "clear-all",
          "title": "Clear All Items",
          "method": "DELETE",
          "layer": "server",
          "status": "built",
          "route": "/api/cart"
        },
        {
          "id": "refresh-expiry",
          "title": "Refresh Expiry",
          "method": "PATCH",
          "layer": "server",
          "status": "built",
          "route": "/api/cart/[id]/expiry"
        }
      ]
    },
    {
      "id": "pre-checkout-validation",
      "title": "Pre-Checkout Validation",
      "trigger": "Buyer initiates checkout",
      "steps": [
        {
          "id": "validate-cart",
          "title": "Validate Cart",
          "method": "POST",
          "layer": "server",
          "status": "built",
          "route": "/api/cart/validate",
          "codeRef": "src/features/cart/services/cart-server.ts",
          "tooltip": "Validates all cart items. Batch block check: single IN query on member_blocks for all unique seller IDs. Blocked items moved to removed[] with reason: 'blocked'."
        },
        {
          "id": "handle-result",
          "title": "Handle Result",
          "layer": "client",
          "status": "built",
          "tooltip": "Handle validation result"
        }
      ],
      "branches": [
        {
          "afterStep": "validate-cart",
          "condition": "Validation result?",
          "paths": [
            {
              "label": "Valid",
              "detail": "Proceed to checkout",
              "goTo": "END"
            },
            {
              "label": "Price Changed",
              "detail": "Acknowledge price changes",
              "goTo": "END"
            },
            {
              "label": "Removed (sold/deleted/deactivated/blocked)",
              "detail": "Items auto-removed from cart. Blocked items show same UX as other removals.",
              "goTo": "END"
            }
          ]
        }
      ]
    }
  ]
}
