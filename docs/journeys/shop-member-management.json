{
  "slug": "shop-member-management",
  "domain": "shops",
  "title": "Shop Member Management (Invite, Remove, Roles)",
  "persona": "shop-owner",
  "description": "Owner manages shop members: invite via email, resend/revoke invites, remove members, and assign roles with permission enforcement.",
  "relatedIssues": [],
  "flows": [
    {
      "id": "invite-member",
      "title": "Invite New Member",
      "trigger": "Owner clicks Invite in Shop Members section",
      "steps": [
        {
          "id": "enter-invite",
          "title": "Enter Invite Details",
          "action": "type",
          "layer": "client",
          "status": "built",
          "tooltip": "Enter email + select role"
        },
        {
          "id": "validate-invite",
          "title": "Validate Input",
          "layer": "client",
          "status": "built",
          "errorCases": [
            {
              "condition": "Invalid email/role",
              "result": "400 error",
              "httpStatus": 400
            }
          ]
        },
        {
          "id": "server-checks",
          "title": "Check Limits",
          "layer": "server",
          "status": "built",
          "tooltip": "Server-side checks: member cap, existing member, duplicate invite",
          "errorCases": [
            {
              "condition": "Members + pending invites >= 5",
              "result": "MEMBER_LIMIT_REACHED",
              "httpStatus": 409
            },
            {
              "condition": "Already a member",
              "result": "409 already a member",
              "httpStatus": 409
            },
            {
              "condition": "Duplicate pending invite",
              "result": "409 duplicate invite",
              "httpStatus": 409
            }
          ]
        },
        {
          "id": "create-invite",
          "title": "Create Invite",
          "method": "POST",
          "layer": "server",
          "status": "built",
          "route": "/api/shops/[id]/invites"
        },
        {
          "id": "insert-invite-row",
          "title": "Insert Invite Row",
          "layer": "database",
          "status": "built",
          "tooltip": "shop_invites row with 7-day expiry"
        },
        {
          "id": "send-email",
          "title": "Send Invite Email",
          "layer": "email",
          "status": "built",
          "tooltip": "Send via Resend with /invite/{token} link"
        }
      ]
    },
    {
      "id": "resend-invite",
      "title": "Resend Invite",
      "trigger": "Owner clicks resend on a pending invite",
      "steps": [
        {
          "id": "click-resend",
          "title": "Resend Invite",
          "method": "POST",
          "layer": "server",
          "status": "built",
          "route": "/api/shops/[id]/invites/[inviteId]/resend"
        },
        {
          "id": "regenerate-token",
          "title": "Regenerate Token",
          "layer": "database",
          "status": "built",
          "tooltip": "Regenerate token + reset expiry to 7 days"
        },
        {
          "id": "resend-email",
          "title": "Resend Email",
          "layer": "email",
          "status": "built",
          "tooltip": "Resend invite email with new token"
        }
      ]
    },
    {
      "id": "revoke-invite",
      "title": "Revoke Invite",
      "trigger": "Owner clicks revoke on a pending invite",
      "steps": [
        {
          "id": "delete-invite",
          "title": "Revoke Invite",
          "method": "DELETE",
          "layer": "server",
          "status": "built",
          "route": "/api/shops/[id]/invites/[inviteId]"
        },
        {
          "id": "set-revoked",
          "title": "Mark as Revoked",
          "layer": "database",
          "status": "built",
          "tooltip": "Set status = 'revoked'"
        }
      ]
    },
    {
      "id": "remove-member",
      "title": "Remove Member",
      "trigger": "Owner clicks remove on a shop member",
      "steps": [
        {
          "id": "delete-member",
          "title": "Remove Member",
          "method": "DELETE",
          "layer": "server",
          "status": "built",
          "route": "/api/shops/[id]/members/[memberId]"
        },
        {
          "id": "member-removed",
          "title": "Delete Membership Row",
          "layer": "database",
          "status": "built",
          "tooltip": "Member removed from shop_members"
        },
        {
          "id": "context-revocation",
          "title": "Trigger Revocation",
          "layer": "background",
          "status": "built",
          "tooltip": "If member was in shop context: 403 on next API call triggers revocation. See context-switching.json."
        }
      ]
    },
    {
      "id": "assign-role",
      "title": "Assign Role",
      "trigger": "Owner selects a new role for a shop member",
      "steps": [
        {
          "id": "show-dropdown",
          "title": "Show Role Dropdown",
          "layer": "client",
          "status": "built",
          "tooltip": "Each member row has RoleSelect dropdown (disabled for owner)"
        },
        {
          "id": "select-role",
          "title": "Select New Role",
          "action": "select",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "patch-role",
          "title": "Update Role",
          "method": "PATCH",
          "layer": "server",
          "status": "built",
          "route": "/api/shops/[id]/members/[memberId]/role",
          "errorCases": [
            {
              "condition": "Cannot assign Owner role",
              "result": "400 error",
              "httpStatus": 400
            }
          ]
        },
        {
          "id": "optimistic-update",
          "title": "Update Cache",
          "layer": "client",
          "status": "built",
          "tooltip": "Optimistic cache update"
        },
        {
          "id": "show-toast",
          "title": "Show Role Toast",
          "layer": "client",
          "status": "built",
          "tooltip": "Toast: 'Role updated to {roleName}'"
        },
        {
          "id": "permissions-change",
          "title": "Apply Permissions",
          "layer": "server",
          "status": "built",
          "tooltip": "Member's permissions change immediately"
        }
      ]
    }
  ]
}
