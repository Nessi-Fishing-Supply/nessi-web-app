{
  "slug": "shop-member-management",
  "title": "Shop Member Management (Invite, Remove, Roles)",
  "persona": "shop-owner",
  "description": "Owner manages shop members: invite via email, resend/revoke invites, remove members, and assign roles with permission enforcement.",
  "relatedIssues": [],
  "flows": [
    {
      "id": "invite-member",
      "title": "Invite New Member",
      "trigger": "Owner clicks Invite in Shop Members section",
      "steps": [
        {
          "id": "enter-invite",
          "label": "Enter email + select role",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "validate-invite",
          "label": "Validate email and role",
          "layer": "client",
          "status": "built",
          "errorCases": [
            { "condition": "Invalid email/role", "result": "400 error", "httpStatus": 400 }
          ]
        },
        {
          "id": "server-checks",
          "label": "Server-side checks: member cap, existing member, duplicate invite",
          "layer": "server",
          "status": "built",
          "errorCases": [
            {
              "condition": "Members + pending invites >= 5",
              "result": "MEMBER_LIMIT_REACHED",
              "httpStatus": 409
            },
            {
              "condition": "Already a member",
              "result": "409 already a member",
              "httpStatus": 409
            },
            {
              "condition": "Duplicate pending invite",
              "result": "409 duplicate invite",
              "httpStatus": 409
            }
          ]
        },
        {
          "id": "create-invite",
          "label": "POST /api/shops/[id]/invites",
          "layer": "server",
          "status": "built",
          "route": "POST /api/shops/[id]/invites"
        },
        {
          "id": "insert-invite-row",
          "label": "Insert shop_invites row with 7-day expiry",
          "layer": "database",
          "status": "built"
        },
        {
          "id": "send-email",
          "label": "Send invite email via Resend with /invite/{token} link",
          "layer": "email",
          "status": "built"
        }
      ]
    },
    {
      "id": "resend-invite",
      "title": "Resend Invite",
      "trigger": "Owner clicks resend on a pending invite",
      "steps": [
        {
          "id": "click-resend",
          "label": "POST /api/shops/[id]/invites/[inviteId]/resend",
          "layer": "server",
          "status": "built",
          "route": "POST /api/shops/[id]/invites/[inviteId]/resend"
        },
        {
          "id": "regenerate-token",
          "label": "Regenerate token + reset expiry to 7 days",
          "layer": "database",
          "status": "built"
        },
        {
          "id": "resend-email",
          "label": "Resend invite email with new token",
          "layer": "email",
          "status": "built"
        }
      ]
    },
    {
      "id": "revoke-invite",
      "title": "Revoke Invite",
      "trigger": "Owner clicks revoke on a pending invite",
      "steps": [
        {
          "id": "delete-invite",
          "label": "DELETE /api/shops/[id]/invites/[inviteId]",
          "layer": "server",
          "status": "built",
          "route": "DELETE /api/shops/[id]/invites/[inviteId]"
        },
        {
          "id": "set-revoked",
          "label": "Set status = 'revoked'",
          "layer": "database",
          "status": "built"
        }
      ]
    },
    {
      "id": "remove-member",
      "title": "Remove Member",
      "trigger": "Owner clicks remove on a shop member",
      "steps": [
        {
          "id": "delete-member",
          "label": "DELETE /api/shops/[id]/members/[memberId]",
          "layer": "server",
          "status": "built",
          "route": "DELETE /api/shops/[id]/members/[memberId]"
        },
        {
          "id": "member-removed",
          "label": "Member removed from shop_members",
          "layer": "database",
          "status": "built"
        },
        {
          "id": "context-revocation",
          "label": "If member was in shop context: 403 on next API call → context revocation",
          "layer": "background",
          "status": "built",
          "notes": "See context-switching.json for revocation safety net."
        }
      ]
    },
    {
      "id": "assign-role",
      "title": "Assign Role",
      "trigger": "Owner selects a new role for a shop member",
      "steps": [
        {
          "id": "show-dropdown",
          "label": "Each member row has RoleSelect dropdown (disabled for owner)",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "select-role",
          "label": "Select new role from dropdown",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "patch-role",
          "label": "PATCH /api/shops/[id]/members/[memberId]/role",
          "layer": "server",
          "status": "built",
          "route": "PATCH /api/shops/[id]/members/[memberId]/role",
          "errorCases": [
            { "condition": "Cannot assign Owner role", "result": "400 error", "httpStatus": 400 }
          ]
        },
        {
          "id": "optimistic-update",
          "label": "Optimistic cache update",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "show-toast",
          "label": "Toast: 'Role updated to {roleName}'",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "permissions-change",
          "label": "Member's permissions change immediately",
          "layer": "server",
          "status": "built"
        }
      ]
    }
  ]
}
