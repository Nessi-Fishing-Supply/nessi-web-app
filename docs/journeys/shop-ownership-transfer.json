{
  "slug": "shop-ownership-transfer",
  "domain": "shops",
  "title": "Shop Ownership Transfer (Request → Accept → Cancel)",
  "persona": "shop-owner",
  "description": "Owner initiates ownership transfer to another member. Transferee receives email link, accepts on a dedicated page. Includes atomic role swap and cancellation flow.",
  "relatedIssues": [],
  "flows": [
    {
      "id": "initiate-transfer",
      "title": "Initiate Transfer",
      "trigger": "Owner clicks Transfer Ownership in shop settings",
      "steps": [
        {
          "id": "select-member",
          "title": "Select New Owner",
          "action": "select",
          "layer": "client",
          "status": "built",
          "tooltip": "Select new owner from current members"
        },
        {
          "id": "confirm-modal",
          "title": "Confirm Transfer",
          "action": "click",
          "layer": "client",
          "status": "built",
          "tooltip": "Two-step confirmation modal"
        },
        {
          "id": "post-transfer",
          "title": "Request Transfer",
          "method": "POST",
          "layer": "server",
          "status": "built",
          "route": "/api/shops/[id]/ownership",
          "errorCases": [
            {
              "condition": "Pending transfer already exists",
              "result": "409 — cancel existing first",
              "httpStatus": 409
            }
          ]
        },
        {
          "id": "insert-transfer",
          "title": "Create Transfer Row",
          "layer": "database",
          "status": "built",
          "tooltip": "Insert shop_ownership_transfers row (status: pending, 7-day expiry)"
        },
        {
          "id": "send-email",
          "title": "Send Transfer Email",
          "layer": "email",
          "status": "built",
          "tooltip": "Ownership transfer email with /shop/transfer/{token} link"
        },
        {
          "id": "show-pending",
          "title": "Show Pending Status",
          "layer": "client",
          "status": "built",
          "tooltip": "Pending status card with transferee name + expiry"
        }
      ]
    },
    {
      "id": "accept-transfer",
      "title": "Accept Transfer",
      "trigger": "Transferee clicks email link → /shop/transfer/{token}",
      "steps": [
        {
          "id": "land-on-page",
          "title": "Open Transfer Page",
          "action": "navigate",
          "layer": "client",
          "status": "built",
          "route": "/shop/transfer/[token]"
        },
        {
          "id": "check-auth",
          "title": "Check Auth",
          "layer": "server",
          "status": "built",
          "tooltip": "proxy.ts: check authentication"
        },
        {
          "id": "validate-transfer",
          "title": "Validate Transfer",
          "layer": "server",
          "status": "built",
          "tooltip": "Server component fetches transfer via admin client — validate status, user, expiry",
          "errorCases": [
            {
              "condition": "Not found or non-pending",
              "result": "notFound()"
            },
            {
              "condition": "Wrong user",
              "result": "notFound()"
            },
            {
              "condition": "Expired",
              "result": "Show expired message"
            }
          ]
        },
        {
          "id": "show-accept",
          "title": "Show Accept UI",
          "layer": "client",
          "status": "built",
          "tooltip": "TransferAccept component"
        },
        {
          "id": "click-accept",
          "title": "Click Accept",
          "action": "click",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "accept-api",
          "title": "Accept Transfer",
          "method": "POST",
          "layer": "server",
          "status": "built",
          "route": "/api/shops/ownership-transfer/[token]/accept"
        },
        {
          "id": "atomic-swap",
          "title": "Swap Ownership",
          "layer": "database",
          "status": "built",
          "tooltip": "Atomic swap: owner_id → new owner, new role → OWNER, old role → MANAGER, status → accepted"
        },
        {
          "id": "transfer-complete",
          "title": "Transfer Complete",
          "layer": "client",
          "status": "built",
          "tooltip": "Ownership transferred successfully"
        }
      ],
      "branches": [
        {
          "afterStep": "check-auth",
          "condition": "Authenticated?",
          "paths": [
            {
              "label": "No",
              "detail": "Redirect to /",
              "goTo": "END"
            },
            {
              "label": "Yes",
              "goTo": "validate-transfer"
            }
          ]
        }
      ]
    },
    {
      "id": "cancel-transfer",
      "title": "Cancel Transfer",
      "trigger": "Owner clicks Cancel Transfer on pending status card",
      "steps": [
        {
          "id": "click-cancel",
          "title": "Click Cancel",
          "action": "click",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "confirm-cancel",
          "title": "Confirm Cancellation",
          "action": "click",
          "layer": "client",
          "status": "built",
          "tooltip": "Confirmation modal"
        },
        {
          "id": "delete-transfer",
          "title": "Cancel Transfer",
          "method": "DELETE",
          "layer": "server",
          "status": "built",
          "route": "/api/shops/[id]/ownership-transfer"
        },
        {
          "id": "set-cancelled",
          "title": "Mark as Cancelled",
          "layer": "database",
          "status": "built",
          "tooltip": "Set transfer status → cancelled"
        }
      ]
    }
  ]
}
