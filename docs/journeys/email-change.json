{
  "slug": "email-change",
  "domain": "auth",
  "title": "Email Change (Authenticated + OTP)",
  "persona": "account",
  "description": "Authenticated user changes their email address from account settings. Requires OTP verification sent to the new email.",
  "relatedIssues": [],
  "flows": [
    {
      "id": "change-email",
      "title": "Change Email with OTP Verification",
      "trigger": "User clicks edit email in /dashboard/account",
      "steps": [
        {
          "id": "click-edit",
          "title": "Click Edit Email",
          "action": "click",
          "layer": "client",
          "status": "built",
          "route": "/dashboard/account"
        },
        {
          "id": "enter-new-email",
          "title": "Enter New Email",
          "action": "type",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "check-availability",
          "title": "Check Availability",
          "layer": "server",
          "status": "built",
          "tooltip": "checkEmailAvailable(email)",
          "errorCases": [
            {
              "condition": "Email already taken",
              "result": "Show error: email taken"
            }
          ]
        },
        {
          "id": "send-change-request",
          "title": "Send Change OTP",
          "layer": "server",
          "status": "built",
          "tooltip": "changeEmail(newEmail) — OTP sent to NEW email"
        },
        {
          "id": "enter-otp",
          "title": "Enter OTP Code",
          "action": "type",
          "layer": "client",
          "status": "built",
          "tooltip": "Enter 6-digit code from new email"
        },
        {
          "id": "verify-otp",
          "title": "Verify Email Change",
          "layer": "server",
          "status": "built",
          "tooltip": "verifyEmailChange(type='email_change')",
          "errorCases": [
            {
              "condition": "Invalid/expired code",
              "result": "Show error"
            }
          ]
        },
        {
          "id": "email-updated",
          "title": "Email Updated",
          "layer": "server",
          "status": "built",
          "tooltip": "Email updated, session persists"
        }
      ],
      "branches": [
        {
          "afterStep": "check-availability",
          "condition": "Email available?",
          "paths": [
            {
              "label": "Yes",
              "goTo": "send-change-request"
            },
            {
              "label": "No",
              "detail": "Email already taken",
              "goTo": "END"
            }
          ]
        },
        {
          "afterStep": "verify-otp",
          "condition": "OTP valid?",
          "paths": [
            {
              "label": "Yes",
              "goTo": "email-updated"
            },
            {
              "label": "No",
              "detail": "Show error, allow retry",
              "goTo": "enter-otp"
            }
          ]
        }
      ]
    }
  ]
}
