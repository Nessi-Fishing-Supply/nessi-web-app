{
  "slug": "shop-settings",
  "domain": "shops",
  "title": "Shop Settings & Deletion",
  "persona": "shop-owner",
  "description": "Shop settings page with sections for details, hero banner, subscription (planned), and shop deletion with full storage cleanup.",
  "relatedIssues": [],
  "flows": [
    {
      "id": "shop-details",
      "title": "Edit Shop Details",
      "trigger": "Owner navigates to /dashboard/shop/settings → Shop Details section",
      "steps": [
        {
          "id": "visit-settings",
          "title": "Open Shop Settings",
          "action": "navigate",
          "layer": "client",
          "status": "built",
          "route": "/dashboard/shop/settings"
        },
        {
          "id": "edit-name",
          "title": "Edit Shop Name",
          "action": "type",
          "layer": "client",
          "status": "built",
          "tooltip": "Inline-edit shop name"
        },
        {
          "id": "edit-slug",
          "title": "Edit Shop Slug",
          "action": "type",
          "layer": "client",
          "status": "built",
          "tooltip": "Edit slug with availability check"
        },
        {
          "id": "edit-description",
          "title": "Edit Description",
          "action": "type",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "upload-avatar",
          "title": "Upload Shop Avatar",
          "method": "POST",
          "action": "upload",
          "layer": "server",
          "status": "built",
          "route": "/api/shops/avatar",
          "tooltip": "200x200 WebP via Sharp"
        }
      ]
    },
    {
      "id": "hero-banner",
      "title": "Upload Hero Banner",
      "trigger": "Owner clicks upload in Hero Banner section",
      "steps": [
        {
          "id": "upload-banner",
          "title": "Select Banner Image",
          "action": "upload",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "process-banner",
          "title": "Process Banner Image",
          "method": "POST",
          "layer": "server",
          "status": "built",
          "route": "/api/shops/hero-banner",
          "tooltip": "Sharp: max 1200x400, convert to WebP"
        },
        {
          "id": "store-banner",
          "title": "Store in Bucket",
          "layer": "server",
          "status": "built",
          "tooltip": "Stored in profile-assets bucket"
        }
      ]
    },
    {
      "id": "delete-shop",
      "title": "Delete Shop",
      "trigger": "Owner clicks Delete Shop in settings",
      "steps": [
        {
          "id": "type-confirmation",
          "title": "Type Confirmation",
          "action": "type",
          "layer": "client",
          "status": "built",
          "tooltip": "Type shop name to confirm deletion"
        },
        {
          "id": "delete-api",
          "title": "Delete Shop",
          "method": "DELETE",
          "layer": "server",
          "status": "built",
          "route": "/api/shops/[id]"
        },
        {
          "id": "delete-avatar",
          "title": "Delete Avatar",
          "layer": "server",
          "status": "built",
          "tooltip": "Delete avatar from storage"
        },
        {
          "id": "delete-hero",
          "title": "Delete Hero Banner",
          "layer": "server",
          "status": "built",
          "tooltip": "Delete hero banner from storage"
        },
        {
          "id": "delete-listing-photos",
          "title": "Delete Listing Photos",
          "layer": "server",
          "status": "built",
          "tooltip": "Delete all shop listing photos from storage"
        },
        {
          "id": "soft-delete-shop",
          "title": "Soft-Delete Shop Row",
          "layer": "database",
          "status": "built"
        },
        {
          "id": "release-slug",
          "title": "Release Slug",
          "layer": "database",
          "status": "built"
        }
      ]
    }
  ]
}
