{
  "slug": "buyer-search",
  "domain": "shopping",
  "title": "Buyer Search & Discovery",
  "persona": "buyer",
  "description": "Authenticated buyer discovers listings via search with autocomplete, category browsing, or homepage featured. Includes filters, infinite scroll, view tracking, and recently viewed.",
  "relatedIssues": [],
  "flows": [
    {
      "id": "search",
      "title": "Search with Autocomplete",
      "trigger": "Buyer types in search bar",
      "steps": [
        {
          "id": "type-query",
          "title": "Type Search Query",
          "action": "type",
          "layer": "client",
          "status": "built",
          "tooltip": "Type 3+ chars triggers autocomplete with 200ms debounce"
        },
        {
          "id": "suggestion-sources",
          "title": "Fetch Suggestions",
          "layer": "server",
          "status": "built",
          "tooltip": "Suggestions from popular search terms, listing titles, category names"
        },
        {
          "id": "select-or-enter",
          "title": "Select or Submit",
          "action": "submit",
          "layer": "client",
          "status": "built",
          "tooltip": "Select suggestion or press Enter"
        },
        {
          "id": "search-page",
          "title": "View Search Results",
          "action": "navigate",
          "layer": "client",
          "status": "built",
          "route": "/search"
        },
        {
          "id": "track-suggestion",
          "title": "Track Suggestion",
          "layer": "background",
          "status": "built",
          "tooltip": "trackSearchSuggestion() — fire and forget"
        }
      ]
    },
    {
      "id": "filter-results",
      "title": "Filter & Browse Results",
      "trigger": "Buyer reaches search or category results page",
      "steps": [
        {
          "id": "filter-panel",
          "title": "Open Filter Panel",
          "action": "select",
          "layer": "client",
          "status": "built",
          "tooltip": "Filter: category, condition (6 tiers), price range, state, species, listing type, free shipping"
        },
        {
          "id": "url-params",
          "title": "Sync Filters to URL",
          "layer": "client",
          "status": "built",
          "tooltip": "All filters stored in URL params (shareable)"
        },
        {
          "id": "infinite-scroll",
          "title": "Scroll Results",
          "action": "scroll",
          "layer": "client",
          "status": "built",
          "tooltip": "Infinite scroll pagination"
        },
        {
          "id": "watch-from-card",
          "title": "Watch from Card",
          "action": "click",
          "layer": "client",
          "status": "built",
          "codeRef": "src/features/listings/components/listing-card/index.tsx",
          "tooltip": "WatchButton overlaid on listing card image. Auth-gated — unauthenticated users are redirected to ?login=true. See member-watchlist.json for the full watch/unwatch flow."
        },
        {
          "id": "click-listing",
          "title": "Click Listing Card",
          "action": "click",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "listing-detail",
          "title": "View Listing Detail",
          "action": "navigate",
          "layer": "client",
          "status": "built",
          "route": "/listing/[id]"
        },
        {
          "id": "view-count",
          "title": "Increment View Count",
          "method": "POST",
          "layer": "server",
          "status": "built",
          "route": "/api/listings/[id]/view"
        },
        {
          "id": "recently-viewed",
          "title": "Track Recently Viewed",
          "layer": "background",
          "status": "built",
          "tooltip": "Recently viewed tracked in background"
        }
      ]
    }
  ]
}
