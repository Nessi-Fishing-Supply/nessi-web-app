{
  "slug": "route-protection",
  "domain": "auth",
  "title": "Route Protection (proxy.ts)",
  "persona": "auth",
  "description": "proxy.ts intercepts every request to enforce auth on /dashboard/*, /shop/transfer, and /watchlist routes, redirect completed onboarding users, and refresh session cookies on public pages.",
  "relatedIssues": [],
  "flows": [
    {
      "id": "route-protection",
      "title": "Request Interception & Auth Enforcement",
      "trigger": "Any incoming request",
      "steps": [
        {
          "id": "receive-request",
          "title": "Intercept Request",
          "layer": "server",
          "status": "built",
          "codeRef": "src/proxy.ts",
          "tooltip": "proxy.ts intercepts incoming request"
        },
        {
          "id": "check-path",
          "title": "Check Request Path",
          "layer": "server",
          "status": "built",
          "tooltip": "Match request path against known patterns"
        },
        {
          "id": "skip-auth",
          "title": "Pass Through",
          "layer": "server",
          "status": "built",
          "tooltip": "Skip auth check for /api/*, /_next/*, /auth/* paths"
        },
        {
          "id": "verify-jwt",
          "title": "Verify JWT",
          "layer": "server",
          "status": "built",
          "tooltip": "getUser() verifies JWT from cookies for /dashboard/*, /shop/transfer, and /watchlist routes"
        },
        {
          "id": "redirect-unauthed",
          "title": "Redirect to Home",
          "layer": "server",
          "status": "built",
          "tooltip": "Redirect unauthenticated users to / when accessing /dashboard/*, /shop/transfer, or /watchlist"
        },
        {
          "id": "check-onboarding",
          "title": "Check Onboarding",
          "layer": "server",
          "status": "built",
          "tooltip": "Check if path is /onboarding and onboarding_completed_at is set"
        },
        {
          "id": "redirect-onboarded",
          "title": "Redirect Onboarded",
          "layer": "server",
          "status": "built",
          "tooltip": "Redirect already-onboarded users away from /onboarding to /"
        },
        {
          "id": "allow-dashboard",
          "title": "Allow Dashboard Access",
          "layer": "server",
          "status": "built",
          "tooltip": "Allow authenticated user through to dashboard"
        },
        {
          "id": "refresh-public",
          "title": "Refresh Public Session",
          "layer": "server",
          "status": "built",
          "tooltip": "Refresh session cookies on public pages, allow through"
        }
      ],
      "branches": [
        {
          "afterStep": "check-path",
          "condition": "Path type?",
          "paths": [
            {
              "label": "API/Static",
              "detail": "/api/*, /_next/*, /auth/* — skip auth",
              "goTo": "skip-auth"
            },
            {
              "label": "Protected",
              "detail": "/dashboard/*, /shop/transfer, /watchlist",
              "goTo": "verify-jwt"
            },
            {
              "label": "Public",
              "goTo": "refresh-public"
            }
          ]
        },
        {
          "afterStep": "verify-jwt",
          "condition": "Authenticated?",
          "paths": [
            {
              "label": "No",
              "goTo": "redirect-unauthed"
            },
            {
              "label": "Yes",
              "goTo": "check-onboarding"
            }
          ]
        },
        {
          "afterStep": "check-onboarding",
          "condition": "Already onboarded?",
          "paths": [
            {
              "label": "Yes",
              "detail": "Path is /onboarding but already completed",
              "goTo": "redirect-onboarded"
            },
            {
              "label": "No",
              "goTo": "allow-dashboard"
            }
          ]
        }
      ]
    }
  ]
}
