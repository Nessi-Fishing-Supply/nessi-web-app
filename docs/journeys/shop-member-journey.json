{
  "slug": "shop-member-journey",
  "domain": "shops",
  "title": "Shop Member Journey (Join, Work, Leave)",
  "persona": "shop-member",
  "description": "Shop member lifecycle: switch to shop context, work within role-based permissions, leave shop with confirmation, and handle context revocation when removed by owner.",
  "relatedIssues": [],
  "flows": [
    {
      "id": "work-in-shop",
      "title": "Work in Shop Context",
      "trigger": "Member clicks shop name in navbar → switchToShop(shopId)",
      "steps": [
        {
          "id": "switch-to-shop",
          "title": "Switch to Shop",
          "action": "click",
          "layer": "client",
          "status": "built",
          "tooltip": "Member clicks shop name in navbar context switcher"
        },
        {
          "id": "set-context-header",
          "title": "Set Context Header",
          "layer": "background",
          "status": "built",
          "tooltip": "X-Nessi-Context: shop:{shopId} set on all requests"
        },
        {
          "id": "create-listing",
          "title": "Create Shop Listing",
          "layer": "client",
          "status": "built",
          "tooltip": "Listing created with shop_id set, visible on shop page"
        },
        {
          "id": "role-based-access",
          "title": "Role-Based Access",
          "layer": "client",
          "status": "built",
          "tooltip": "Owner/Manager: settings + members. Contributor: own listings only."
        },
        {
          "id": "switch-back",
          "title": "Switch to Personal",
          "action": "click",
          "layer": "client",
          "status": "built",
          "tooltip": "switchToMember() — X-Nessi-Context: member"
        }
      ],
      "branches": [
        {
          "afterStep": "set-context-header",
          "condition": "Role?",
          "paths": [
            {
              "label": "Owner/Manager",
              "detail": "Access shop settings, manage members, edit any listing",
              "goTo": "create-listing"
            },
            {
              "label": "Contributor",
              "detail": "Edit own listings only, no settings/members access",
              "goTo": "create-listing"
            }
          ]
        }
      ]
    },
    {
      "id": "leave-shop",
      "title": "Leave Shop (Non-Owner)",
      "trigger": "Non-owner member clicks 'Leave Shop'",
      "steps": [
        {
          "id": "click-leave",
          "title": "Click Leave Shop",
          "action": "click",
          "layer": "client",
          "status": "built",
          "tooltip": "Leave button NOT shown for owners — must transfer ownership first"
        },
        {
          "id": "confirm-modal",
          "title": "Open Confirm Modal",
          "action": "open",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "type-phrase",
          "title": "Type Confirmation",
          "action": "type",
          "layer": "client",
          "status": "built",
          "tooltip": "Type: 'I {name} want to leave {shopName}'"
        },
        {
          "id": "remove-self",
          "title": "Leave Shop",
          "layer": "server",
          "status": "built",
          "tooltip": "removeShopMember(shopId, myMemberId)"
        },
        {
          "id": "switch-to-member",
          "title": "Revert to Personal",
          "layer": "background",
          "status": "built",
          "tooltip": "switchToMember() — revert to personal context"
        },
        {
          "id": "invalidate-queries",
          "title": "Invalidate Queries",
          "layer": "background",
          "status": "built",
          "tooltip": "Invalidate shop queries"
        },
        {
          "id": "show-toast",
          "title": "Show Left Toast",
          "layer": "client",
          "status": "built",
          "tooltip": "Toast: 'You left {shopName}'"
        },
        {
          "id": "close-modal",
          "title": "Close Modal",
          "action": "close",
          "layer": "client",
          "status": "built",
          "tooltip": "Modal closes, user in member context"
        }
      ],
      "branches": [
        {
          "afterStep": "type-phrase",
          "condition": "Phrase matches?",
          "paths": [
            {
              "label": "Yes",
              "goTo": "remove-self"
            },
            {
              "label": "No",
              "detail": "Submit button disabled",
              "goTo": "END"
            }
          ]
        }
      ]
    },
    {
      "id": "context-revocation",
      "title": "Context Revocation (Removed by Owner)",
      "trigger": "Owner removes member while member is in shop context",
      "steps": [
        {
          "id": "owner-removes",
          "title": "Owner Removes Member",
          "layer": "server",
          "status": "built",
          "tooltip": "Owner removes member from shop via API"
        },
        {
          "id": "next-api-call",
          "title": "Next API Call",
          "layer": "background",
          "status": "built",
          "tooltip": "Member's next API call includes shop context"
        },
        {
          "id": "receive-403",
          "title": "Receive 403",
          "layer": "server",
          "status": "built",
          "tooltip": "API returns 403 Forbidden"
        },
        {
          "id": "handle-revocation",
          "title": "Handle Revocation",
          "layer": "background",
          "status": "built",
          "tooltip": "handleContextRevocation() fires with 2s dedup check"
        },
        {
          "id": "switch-to-member",
          "title": "Revert to Personal",
          "layer": "background",
          "status": "built",
          "tooltip": "switchToMember() — revert to personal context"
        },
        {
          "id": "cancel-queries",
          "title": "Cancel All Queries",
          "layer": "background",
          "status": "built",
          "tooltip": "Cancel all queries + invalidate cache"
        },
        {
          "id": "dispatch-event",
          "title": "Dispatch Event",
          "layer": "background",
          "status": "built",
          "tooltip": "Dispatch 'nessi:context-revoked' event"
        },
        {
          "id": "show-toast",
          "title": "Show Removed Toast",
          "layer": "client",
          "status": "built",
          "tooltip": "ContextRevocationListener — Toast: 'You have been removed from shop'"
        },
        {
          "id": "navigate-dashboard",
          "title": "Go to Dashboard",
          "action": "navigate",
          "layer": "client",
          "status": "built",
          "tooltip": "Navigate to /dashboard"
        }
      ]
    },
    {
      "id": "multi-shop",
      "title": "Multi-Shop Member",
      "trigger": "User belongs to multiple shops",
      "steps": [
        {
          "id": "fetch-shops",
          "title": "Fetch User Shops",
          "layer": "server",
          "status": "built",
          "tooltip": "getShopsByMember(memberId) — fetch all shops"
        },
        {
          "id": "navbar-dropdown",
          "title": "Show Shop Dropdown",
          "layer": "client",
          "status": "built",
          "tooltip": "Navbar dropdown lists all shops + personal profile"
        },
        {
          "id": "select-identity",
          "title": "Select Identity",
          "action": "select",
          "layer": "client",
          "status": "built",
          "tooltip": "Select identity: personal, or any shop (with role)"
        },
        {
          "id": "set-context",
          "title": "Set Context Store",
          "layer": "background",
          "status": "built",
          "tooltip": "Set context in Zustand store"
        },
        {
          "id": "persist-context",
          "title": "Persist to Storage",
          "layer": "background",
          "status": "built",
          "tooltip": "Persisted to localStorage — survives page refresh"
        }
      ]
    }
  ]
}
