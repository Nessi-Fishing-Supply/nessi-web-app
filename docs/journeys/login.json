{
  "slug": "login",
  "domain": "auth",
  "title": "Login (Email + Password)",
  "persona": "auth",
  "description": "Existing user logs in with email and password. Triggers background cart merge and recently-viewed merge as side effects.",
  "relatedIssues": [],
  "flows": [
    {
      "id": "login",
      "title": "Sign In with Email & Password",
      "trigger": "User clicks Log In in navbar modal",
      "steps": [
        {
          "id": "open-modal",
          "title": "Open Login Modal",
          "action": "click",
          "layer": "client",
          "status": "built",
          "tooltip": "User clicks Log In in navbar, modal opens"
        },
        {
          "id": "enter-credentials",
          "title": "Enter Credentials",
          "action": "type",
          "layer": "client",
          "status": "built",
          "tooltip": "Enter email + password"
        },
        {
          "id": "sign-in",
          "title": "Authenticate User",
          "layer": "server",
          "status": "built",
          "tooltip": "signInWithPassword() called via Supabase client",
          "errorCases": [
            {
              "condition": "email_not_confirmed",
              "result": "Show inline resend verification button"
            },
            {
              "condition": "Invalid credentials",
              "result": "Show error message"
            }
          ]
        },
        {
          "id": "session-set",
          "title": "Set Session Cookies",
          "layer": "server",
          "status": "built",
          "tooltip": "Session cookies set on successful authentication"
        },
        {
          "id": "close-modal",
          "title": "Close Modal",
          "action": "close",
          "layer": "client",
          "status": "built",
          "tooltip": "onSuccess callback fires, modal closes"
        },
        {
          "id": "stay-on-page",
          "title": "Stay on Current Page",
          "layer": "client",
          "status": "built",
          "tooltip": "User stays on current page after login"
        }
      ],
      "branches": [
        {
          "afterStep": "sign-in",
          "condition": "Auth result?",
          "paths": [
            {
              "label": "Unconfirmed",
              "detail": "email_not_confirmed — show resend button",
              "goTo": "END"
            },
            {
              "label": "Invalid",
              "detail": "Invalid credentials — show error message",
              "goTo": "END"
            },
            {
              "label": "Success",
              "goTo": "session-set"
            }
          ]
        }
      ]
    },
    {
      "id": "post-login-side-effects",
      "title": "Post-Login Background Side Effects",
      "trigger": "Session established after login",
      "steps": [
        {
          "id": "cart-merge",
          "title": "Merge Guest Cart",
          "layer": "background",
          "status": "built",
          "codeRef": "src/features/cart/hooks/use-cart-merge.ts",
          "tooltip": "useCartMerge() merges localStorage cart to DB. Silent, no toast. See guest-cart.json."
        },
        {
          "id": "recently-viewed-merge",
          "title": "Merge Recently Viewed",
          "layer": "background",
          "status": "built",
          "codeRef": "src/features/recently-viewed/hooks/use-recently-viewed-merge.ts",
          "tooltip": "useRecentlyViewedMerge() — POST /api/recently-viewed/merge. Deduplicates on server. Silent."
        }
      ]
    },
    {
      "id": "resend-verification",
      "title": "Resend Email Verification",
      "trigger": "Login fails with email_not_confirmed error",
      "steps": [
        {
          "id": "show-resend-button",
          "title": "Show Resend Button",
          "layer": "client",
          "status": "built",
          "tooltip": "Inline resend verification button appears"
        },
        {
          "id": "resend-otp",
          "title": "Resend OTP",
          "layer": "server",
          "status": "built",
          "tooltip": "resendOtp() sends new verification code to user's email"
        },
        {
          "id": "verify-then-login",
          "title": "Verify Then Login",
          "layer": "client",
          "status": "built",
          "tooltip": "User verifies email, then logs in again"
        }
      ]
    }
  ]
}
