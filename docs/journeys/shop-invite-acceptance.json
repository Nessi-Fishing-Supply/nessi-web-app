{
  "slug": "shop-invite-acceptance",
  "domain": "shops",
  "title": "Shop Invite → Accept (or Register & Auto-Accept)",
  "persona": "shop-member",
  "description": "A user receives a shop invite email, lands on the invite page, and either accepts directly (if authenticated) or registers a new account with auto-accept.",
  "relatedIssues": [250, 251, 252, 253, 254, 255],
  "flows": [
    {
      "id": "invite-sent",
      "title": "Owner Sends Invite",
      "trigger": "Shop owner clicks 'Invite' in Shop Members section",
      "steps": [
        {
          "id": "open-modal",
          "title": "Click Invite Button",
          "action": "click",
          "layer": "client",
          "status": "built",
          "codeRef": "src/features/shops/components/invite-member-modal/index.tsx"
        },
        {
          "id": "enter-details",
          "title": "Enter Invite Details",
          "action": "type",
          "layer": "client",
          "status": "built",
          "tooltip": "Enter recipient email + select role. RoleSelect filters out Owner. Validates via validateInviteInput()."
        },
        {
          "id": "create-invite",
          "title": "Create Invite",
          "method": "POST",
          "layer": "server",
          "status": "built",
          "route": "/api/shops/[id]/invites",
          "codeRef": "src/app/api/shops/[id]/invites/route.ts",
          "tooltip": "Requires requireShopPermission('members', 'full'). Enforces 5-member cap.",
          "errorCases": [
            {
              "condition": "Members + pending invites >= 5",
              "result": "MEMBER_LIMIT_REACHED",
              "httpStatus": 409
            },
            {
              "condition": "Email already a shop member",
              "result": "ALREADY_MEMBER",
              "httpStatus": 409
            },
            {
              "condition": "Duplicate pending invite for same email",
              "result": "DUPLICATE_INVITE",
              "httpStatus": 409
            }
          ]
        },
        {
          "id": "insert-row",
          "title": "Insert Invite Row",
          "layer": "database",
          "status": "built",
          "tooltip": "shop_invites row with 7-day expiry token"
        },
        {
          "id": "send-email",
          "title": "Send Invite Email",
          "layer": "email",
          "status": "built",
          "codeRef": "src/features/email/templates/shop-invite.tsx",
          "tooltip": "Send via Resend with /invite/{token} link. Email failure logged but does NOT block 201 response."
        }
      ]
    },
    {
      "id": "accept-authenticated",
      "title": "Accept Invite (Already Logged In)",
      "trigger": "Authenticated user clicks invite link from email",
      "steps": [
        {
          "id": "land-on-page",
          "title": "Open Invite Page",
          "action": "navigate",
          "layer": "client",
          "status": "built",
          "route": "/invite/[token]",
          "codeRef": "src/app/(frontend)/invite/[token]/page.tsx",
          "tooltip": "Server component fetches invite data via admin client. Invalid token → 404."
        },
        {
          "id": "check-auth",
          "title": "Check Auth Session",
          "layer": "client",
          "status": "built",
          "codeRef": "src/features/shops/components/invite-accept/index.tsx",
          "tooltip": "InviteAccept checks useAuth() session"
        },
        {
          "id": "show-accept-button",
          "title": "Show Accept Button",
          "layer": "client",
          "status": "built",
          "tooltip": "Shows shop name, avatar, inviter name, assigned role"
        },
        {
          "id": "click-accept",
          "title": "Click Accept",
          "action": "click",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "accept-api",
          "title": "Accept Invite",
          "method": "POST",
          "layer": "server",
          "status": "built",
          "route": "/api/invites/[token]/accept",
          "codeRef": "src/app/api/invites/[token]/accept/route.ts",
          "tooltip": "Cookie session auth (no X-Nessi-Context). Looks up invite by token via admin client.",
          "errorCases": [
            {
              "condition": "Already a shop member",
              "result": "ALREADY_MEMBER",
              "httpStatus": 409
            },
            {
              "condition": "Shop at member cap",
              "result": "MEMBER_LIMIT_REACHED",
              "httpStatus": 409
            },
            {
              "condition": "Member belongs to 5 shops",
              "result": "SHOP_LIMIT_REACHED",
              "httpStatus": 409
            },
            {
              "condition": "Invite expired",
              "result": "INVITE_EXPIRED",
              "httpStatus": 400
            },
            {
              "condition": "Invite revoked",
              "result": "INVITE_REVOKED",
              "httpStatus": 400
            }
          ]
        },
        {
          "id": "insert-membership",
          "title": "Create Membership",
          "layer": "database",
          "status": "built",
          "tooltip": "Insert shop_members row with invite's role_id"
        },
        {
          "id": "mark-accepted",
          "title": "Mark Accepted",
          "layer": "database",
          "status": "built",
          "tooltip": "Update shop_invites status = 'accepted'"
        },
        {
          "id": "redirect-success",
          "title": "Redirect to Dashboard",
          "action": "navigate",
          "layer": "client",
          "status": "built",
          "tooltip": "Redirect to /dashboard + success toast. Shop now in navbar context switcher."
        }
      ],
      "branches": [
        {
          "afterStep": "land-on-page",
          "condition": "Invite valid?",
          "paths": [
            {
              "label": "Pending",
              "detail": "Not expired",
              "goTo": "check-auth"
            },
            {
              "label": "Expired",
              "goTo": "END"
            },
            {
              "label": "Revoked",
              "goTo": "END"
            },
            {
              "label": "Accepted",
              "detail": "Already accepted",
              "goTo": "END"
            }
          ]
        }
      ]
    },
    {
      "id": "accept-new-user",
      "title": "Register & Auto-Accept (New User)",
      "trigger": "Unauthenticated new user clicks invite link, then signs up",
      "steps": [
        {
          "id": "land-unauthenticated",
          "title": "Open Invite Page",
          "action": "navigate",
          "layer": "client",
          "status": "built",
          "route": "/invite/[token]",
          "tooltip": "User lands without session"
        },
        {
          "id": "show-auth-options",
          "title": "Show Auth Options",
          "layer": "client",
          "status": "built",
          "tooltip": "Show Sign Up and Sign In buttons (no Accept yet). Sign Up navigates to ?register=true&invite={token}"
        },
        {
          "id": "click-signup",
          "title": "Click Sign Up",
          "action": "click",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "navbar-detects-params",
          "title": "Detect Invite Params",
          "layer": "background",
          "status": "built",
          "codeRef": "src/components/navigation/navbar/index.tsx",
          "tooltip": "Navbar useEffect detects ?register=true&invite={token}. Stores inviteToken, opens register modal, cleans URL."
        },
        {
          "id": "register",
          "title": "Register Account",
          "method": "POST",
          "layer": "server",
          "status": "built",
          "route": "/api/auth/register",
          "tooltip": "User enters email + password, submits registration"
        },
        {
          "id": "otp-verify",
          "title": "Verify OTP Code",
          "action": "type",
          "layer": "client",
          "status": "built",
          "tooltip": "6-digit OTP code → verifyOtp(type='signup'). inviteToken threaded: Navbar → RegisterForm → OtpInput."
        },
        {
          "id": "session-established",
          "title": "Set Session",
          "layer": "server",
          "status": "built",
          "tooltip": "Session established via cookies"
        },
        {
          "id": "auto-accept",
          "title": "Auto-Accept Invite",
          "layer": "background",
          "status": "built",
          "codeRef": "src/features/shops/services/shop-invites.ts",
          "tooltip": "acceptShopInvite(token) called in OtpInput after verify. Failure NEVER blocks — account always completes."
        },
        {
          "id": "auto-accept-success",
          "title": "Show Joined Toast",
          "layer": "client",
          "status": "built",
          "tooltip": "Toast: 'You've joined {shopName}!' + redirect to /dashboard. onInviteAccepted callback fires."
        }
      ],
      "branches": [
        {
          "afterStep": "auto-accept",
          "condition": "Accept result?",
          "paths": [
            {
              "label": "Success",
              "goTo": "auto-accept-success"
            },
            {
              "label": "Failure",
              "detail": "Toast suggests manual acceptance",
              "goTo": "END"
            }
          ]
        }
      ]
    }
  ]
}
