{
  "slug": "seller-social-sharing",
  "domain": "listings",
  "title": "Listing Social Sharing",
  "persona": "seller",
  "description": "Share listing via Web Share API (mobile) or clipboard copy (desktop). Handles API availability, cancellation, and clipboard permission gracefully.",
  "relatedIssues": [],
  "flows": [
    {
      "id": "share-listing",
      "title": "Share Listing URL",
      "trigger": "User clicks ShareButton on listing detail page",
      "steps": [
        {
          "id": "click-share",
          "title": "Click Share Button",
          "action": "click",
          "layer": "client",
          "status": "built",
          "tooltip": "ShareButton in action bar on listing detail page"
        },
        {
          "id": "check-api",
          "title": "Check Share API",
          "layer": "client",
          "status": "built",
          "tooltip": "Check if Web Share API is available"
        },
        {
          "id": "native-share",
          "title": "Open Native Share",
          "layer": "client",
          "status": "built",
          "tooltip": "navigator.share({ title, url }) — native share sheet opens (mobile). AbortError from cancellation silently ignored."
        },
        {
          "id": "clipboard-copy",
          "title": "Copy Link",
          "layer": "client",
          "status": "built",
          "tooltip": "navigator.clipboard.writeText(url) — copy link to clipboard (desktop)"
        },
        {
          "id": "copy-success",
          "title": "Show Copied Toast",
          "layer": "client",
          "status": "built",
          "tooltip": "Toast: 'Link copied!'"
        },
        {
          "id": "copy-denied",
          "title": "Show Error Toast",
          "layer": "client",
          "status": "built",
          "tooltip": "Toast: 'Unable to copy link' (clipboard access denied)"
        }
      ],
      "branches": [
        {
          "afterStep": "check-api",
          "condition": "Share API available?",
          "paths": [
            {
              "label": "Yes",
              "detail": "Mobile — native share sheet",
              "goTo": "native-share"
            },
            {
              "label": "No",
              "detail": "Desktop — clipboard copy",
              "goTo": "clipboard-copy"
            }
          ]
        },
        {
          "afterStep": "clipboard-copy",
          "condition": "Clipboard access?",
          "paths": [
            {
              "label": "Success",
              "goTo": "copy-success"
            },
            {
              "label": "Denied",
              "goTo": "copy-denied"
            }
          ]
        }
      ]
    }
  ]
}
