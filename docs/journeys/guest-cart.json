{
  "slug": "guest-cart",
  "domain": "cart",
  "title": "Guest Cart → Login → Merge",
  "persona": "guest",
  "description": "Guest adds items to localStorage cart, logs in, and cart silently merges to the database.",
  "relatedIssues": [
    128,
    129,
    130
  ],
  "flows": [
    {
      "id": "add-to-cart",
      "title": "Add Item to Guest Cart",
      "trigger": "Guest clicks 'Add to Cart' on listing detail page",
      "steps": [
        {
          "id": "click-add",
          "title": "Click Add to Cart",
          "action": "click",
          "layer": "client",
          "status": "built",
          "codeRef": "src/features/cart/components/add-to-cart-button/index.tsx"
        },
        {
          "id": "validate-client",
          "title": "Validate Cart State",
          "layer": "client",
          "status": "built",
          "tooltip": "Client-side validation: own listing, already in cart, cart full",
          "errorCases": [
            {
              "condition": "User's own listing",
              "result": "Button disabled"
            },
            {
              "condition": "Already in cart",
              "result": "Button shows 'In Cart'"
            },
            {
              "condition": "Cart has 25 items",
              "result": "Toast: cart full"
            }
          ]
        },
        {
          "id": "write-localstorage",
          "title": "Save to localStorage",
          "layer": "background",
          "status": "built",
          "tooltip": "Add item to localStorage cart (listingId + priceCents snapshot). No API calls."
        },
        {
          "id": "update-badge",
          "title": "Update Cart Badge",
          "layer": "client",
          "status": "built",
          "tooltip": "CartIcon badge count updates via Zustand store"
        },
        {
          "id": "show-toast",
          "title": "Show Added Toast",
          "layer": "client",
          "status": "built",
          "tooltip": "Toast: 'Added to cart'"
        }
      ]
    },
    {
      "id": "view-cart",
      "title": "View Guest Cart",
      "trigger": "Guest navigates to /cart",
      "steps": [
        {
          "id": "load-cart",
          "title": "Read localStorage Cart",
          "layer": "background",
          "status": "built"
        },
        {
          "id": "group-by-seller",
          "title": "Group by Seller",
          "layer": "client",
          "status": "built",
          "codeRef": "src/app/(frontend)/cart/page.tsx",
          "tooltip": "Items grouped by seller for display"
        },
        {
          "id": "show-items",
          "title": "Render Cart Items",
          "layer": "client",
          "status": "built",
          "tooltip": "Cart items with remove/clear actions. Checkout button disabled in MVP."
        }
      ],
      "branches": [
        {
          "afterStep": "load-cart",
          "condition": "Has items?",
          "paths": [
            {
              "label": "Yes",
              "goTo": "group-by-seller"
            },
            {
              "label": "No",
              "detail": "Empty state + browse CTA",
              "goTo": "END"
            }
          ]
        }
      ]
    },
    {
      "id": "merge-on-login",
      "title": "Cart Merge on Login",
      "trigger": "Guest logs in with items in localStorage cart",
      "steps": [
        {
          "id": "login-detected",
          "title": "Detect Auth Change",
          "layer": "background",
          "status": "built",
          "codeRef": "src/features/cart/hooks/use-cart-merge.ts",
          "tooltip": "useCartMerge() detects auth state change. Background hook — user sees nothing."
        },
        {
          "id": "read-guest-cart",
          "title": "Read Guest Cart",
          "layer": "background",
          "status": "built",
          "tooltip": "Read localStorage cart items"
        },
        {
          "id": "post-merge",
          "title": "Merge Cart to DB",
          "method": "POST",
          "layer": "server",
          "status": "built",
          "route": "/api/cart/merge",
          "tooltip": "Server validates every guest item: listing exists, not sold, not own listing, not already in DB cart."
        },
        {
          "id": "server-validate",
          "title": "Skip Invalid Items",
          "layer": "server",
          "status": "built",
          "tooltip": "Invalid/duplicate/own-listing items silently dropped. No errors surfaced to user."
        },
        {
          "id": "insert-valid",
          "title": "Insert Valid Items",
          "layer": "database",
          "status": "built",
          "tooltip": "Insert valid items into cart table"
        },
        {
          "id": "clear-localstorage",
          "title": "Clear Guest Cart",
          "layer": "background",
          "status": "built",
          "tooltip": "Clear localStorage guest cart. No toast, no redirect. Cart page now shows DB-backed items."
        }
      ]
    }
  ]
}
