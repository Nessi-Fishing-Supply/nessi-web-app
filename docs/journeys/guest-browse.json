{
  "slug": "guest-browse",
  "domain": "shopping",
  "title": "Guest Browse & Discover",
  "persona": "guest",
  "description": "Unauthenticated user browses the marketplace by category, keyword search, or featured listings. Views listing details, seller profiles, and shop pages.",
  "relatedIssues": [],
  "flows": [
    {
      "id": "browse-by-category",
      "title": "Browse by Category",
      "trigger": "Guest clicks a category on the homepage",
      "steps": [
        {
          "id": "land-homepage",
          "title": "Land on Homepage",
          "action": "navigate",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "click-category",
          "title": "Click Category",
          "action": "click",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "category-page",
          "title": "View Category Page",
          "action": "navigate",
          "layer": "client",
          "status": "built",
          "route": "/category/[slug]"
        },
        {
          "id": "apply-filters",
          "title": "Apply Filters",
          "action": "select",
          "layer": "client",
          "status": "built",
          "tooltip": "Filter: condition, price, state, species, listing type. All filters stored in URL params (shareable)."
        },
        {
          "id": "infinite-scroll",
          "title": "Scroll Results",
          "action": "scroll",
          "layer": "client",
          "status": "built",
          "tooltip": "Infinite scroll pagination"
        },
        {
          "id": "click-listing",
          "title": "Click Listing Card",
          "action": "click",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "listing-detail",
          "title": "View Listing Detail",
          "action": "navigate",
          "layer": "client",
          "status": "built",
          "route": "/listing/[id]"
        },
        {
          "id": "view-count",
          "title": "Increment View Count",
          "layer": "server",
          "status": "built",
          "tooltip": "View count incremented on listing detail page load"
        }
      ]
    },
    {
      "id": "search-by-keyword",
      "title": "Search by Keyword",
      "trigger": "Guest types in search bar",
      "steps": [
        {
          "id": "type-search",
          "title": "Type Search Query",
          "action": "type",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "autocomplete",
          "title": "Show Autocomplete",
          "layer": "client",
          "status": "built",
          "tooltip": "Suggestions appear after 3+ chars with 200ms debounce"
        },
        {
          "id": "select-or-enter",
          "title": "Select or Submit",
          "action": "submit",
          "layer": "client",
          "status": "built",
          "tooltip": "Select suggestion or press Enter"
        },
        {
          "id": "search-results",
          "title": "View Search Results",
          "action": "navigate",
          "layer": "client",
          "status": "built",
          "route": "/search"
        },
        {
          "id": "filter-results",
          "title": "Apply Filters",
          "action": "select",
          "layer": "client",
          "status": "built",
          "tooltip": "Filter: condition, price, state, species, listing type"
        },
        {
          "id": "scroll-results",
          "title": "Scroll Results",
          "action": "scroll",
          "layer": "client",
          "status": "built",
          "tooltip": "Infinite scroll pagination"
        }
      ]
    },
    {
      "id": "view-profiles",
      "title": "View Seller & Shop Profiles",
      "trigger": "Guest clicks seller or shop link on listing detail",
      "steps": [
        {
          "id": "click-seller",
          "title": "Click Seller Link",
          "action": "click",
          "layer": "client",
          "status": "built",
          "tooltip": "Click seller profile link on listing detail"
        },
        {
          "id": "member-page",
          "title": "View Seller Profile",
          "action": "navigate",
          "layer": "client",
          "status": "built",
          "route": "/member/[slug]"
        },
        {
          "id": "seller-listings",
          "title": "Browse Seller Items",
          "layer": "client",
          "status": "built",
          "tooltip": "See seller's other listings"
        },
        {
          "id": "click-shop",
          "title": "Click Shop Link",
          "action": "click",
          "layer": "client",
          "status": "built",
          "tooltip": "Click shop page link on listing detail"
        },
        {
          "id": "shop-page",
          "title": "View Shop Page",
          "action": "navigate",
          "layer": "client",
          "status": "built",
          "route": "/shop/[slug]"
        },
        {
          "id": "shop-listings",
          "title": "Browse Shop Items",
          "layer": "client",
          "status": "built",
          "tooltip": "Shop's listings grid + hero banner"
        }
      ]
    }
  ]
}
