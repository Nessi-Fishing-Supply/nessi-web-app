{
  "slug": "account-settings",
  "domain": "account",
  "title": "Account Settings & Profile Completeness",
  "persona": "account",
  "description": "Account settings page with sections for personal info, fishing identity, notifications, seller settings, shipping addresses, linked accounts, and profile completeness tracking.",
  "relatedIssues": [],
  "flows": [
    {
      "id": "settings-sections",
      "title": "Account Settings Page",
      "trigger": "User navigates to /dashboard/account",
      "steps": [
        {
          "id": "visit-account",
          "title": "Open Account Page",
          "action": "navigate",
          "layer": "client",
          "status": "built",
          "route": "/dashboard/account"
        },
        {
          "id": "personal-info",
          "title": "Edit Personal Info",
          "action": "type",
          "layer": "client",
          "status": "built",
          "tooltip": "Display name, bio (280 chars), avatar upload (200x200 WebP). Email change triggers OTP — see email-change.json."
        },
        {
          "id": "fishing-identity",
          "title": "Edit Fishing Identity",
          "action": "select",
          "layer": "client",
          "status": "built",
          "tooltip": "Species (multi), technique (multi), home state, years fishing"
        },
        {
          "id": "notifications",
          "title": "Email Preferences",
          "action": "toggle",
          "layer": "client",
          "status": "built",
          "tooltip": "Notification email preferences (JSONB)"
        },
        {
          "id": "seller-settings",
          "title": "Seller Settings",
          "action": "toggle",
          "layer": "client",
          "status": "built",
          "tooltip": "Toggle seller on/off — see seller-toggle.json"
        },
        {
          "id": "shipping-addresses",
          "title": "Shipping Addresses",
          "layer": "client",
          "status": "built",
          "tooltip": "View/add/edit/delete (max 5) — see buyer-addresses.json"
        },
        {
          "id": "linked-accounts",
          "title": "Linked Accounts",
          "layer": "client",
          "status": "planned",
          "tooltip": "Stripe Connect placeholder"
        },
        {
          "id": "danger-zone",
          "title": "Danger Zone",
          "layer": "client",
          "status": "built",
          "tooltip": "Delete Account — see account-deletion.json"
        }
      ]
    },
    {
      "id": "profile-completeness",
      "title": "Profile Completeness Tracker",
      "trigger": "MemberCompleteness component renders on dashboard",
      "steps": [
        {
          "id": "check-fields",
          "title": "Check Profile Fields",
          "layer": "client",
          "status": "built",
          "tooltip": "Check: has avatar, has bio, has fishing identity, has display name"
        },
        {
          "id": "calculate-percentage",
          "title": "Calculate Percentage",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "show-progress",
          "title": "Show Progress Bar",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "show-suggestions",
          "title": "Show Suggestions",
          "layer": "client",
          "status": "built",
          "tooltip": "Suggestions for missing fields (if not 100%)"
        },
        {
          "id": "complete-badge",
          "title": "Show Complete Badge",
          "layer": "client",
          "status": "built",
          "tooltip": "Profile complete badge when 100%"
        }
      ],
      "branches": [
        {
          "afterStep": "show-progress",
          "condition": "100% complete?",
          "paths": [
            {
              "label": "No",
              "goTo": "show-suggestions"
            },
            {
              "label": "Yes",
              "goTo": "complete-badge"
            }
          ]
        }
      ]
    }
  ]
}
