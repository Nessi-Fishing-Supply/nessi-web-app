{
  "slug": "buyer-recently-viewed",
  "domain": "shopping",
  "title": "Recently Viewed (Dual-Source)",
  "persona": "buyer",
  "description": "Recently viewed listings use dual-source storage: localStorage for guests, DB-backed API for authenticated users. Includes merge on login and clear history.",
  "relatedIssues": [],
  "flows": [
    {
      "id": "track-view",
      "title": "Track Listing View",
      "trigger": "User views a listing detail page",
      "steps": [
        {
          "id": "view-listing",
          "title": "View Listing Detail",
          "action": "navigate",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "track-authenticated",
          "title": "Track View in DB",
          "method": "POST",
          "layer": "server",
          "status": "built",
          "route": "/api/recently-viewed"
        },
        {
          "id": "track-guest",
          "title": "Track View Locally",
          "layer": "background",
          "status": "built",
          "tooltip": "addRecentlyViewed() saves to localStorage"
        }
      ],
      "branches": [
        {
          "afterStep": "view-listing",
          "condition": "Authenticated?",
          "paths": [
            {
              "label": "Yes",
              "goTo": "track-authenticated"
            },
            {
              "label": "No",
              "goTo": "track-guest"
            }
          ]
        }
      ]
    },
    {
      "id": "browse-history",
      "title": "Browse Recently Viewed",
      "trigger": "User navigates to recently viewed section",
      "steps": [
        {
          "id": "fetch-authenticated",
          "title": "Fetch from API",
          "method": "GET",
          "layer": "server",
          "status": "built",
          "route": "/api/recently-viewed",
          "tooltip": "Returns recently viewed with listing data"
        },
        {
          "id": "fetch-guest",
          "title": "Fetch from Storage",
          "layer": "background",
          "status": "built",
          "tooltip": "getRecentlyViewed() from localStorage"
        }
      ],
      "branches": [
        {
          "afterStep": "browse-history",
          "condition": "Authenticated?",
          "paths": [
            {
              "label": "Yes",
              "goTo": "fetch-authenticated"
            },
            {
              "label": "No",
              "goTo": "fetch-guest"
            }
          ]
        }
      ]
    },
    {
      "id": "merge-on-login",
      "title": "Merge on Login",
      "trigger": "Guest logs in with localStorage recently viewed items",
      "steps": [
        {
          "id": "detect-login",
          "title": "Detect Login",
          "layer": "background",
          "status": "built",
          "codeRef": "src/features/recently-viewed/hooks/use-recently-viewed-merge.ts",
          "tooltip": "useRecentlyViewedMerge() detects login"
        },
        {
          "id": "post-merge",
          "title": "Merge Views to DB",
          "method": "POST",
          "layer": "server",
          "status": "built",
          "route": "/api/recently-viewed/merge"
        },
        {
          "id": "dedup-merge",
          "title": "Dedup and Insert",
          "layer": "database",
          "status": "built",
          "tooltip": "Dedup + merge to DB"
        },
        {
          "id": "silent-complete",
          "title": "Silent Complete",
          "layer": "background",
          "status": "built",
          "tooltip": "No toast — silent merge"
        }
      ]
    },
    {
      "id": "display-strip",
      "title": "Display Recently Viewed Strip",
      "trigger": "User visits homepage or category browse page",
      "steps": [
        {
          "id": "hook-reads-ids",
          "title": "Read View IDs",
          "layer": "background",
          "status": "built",
          "codeRef": "src/features/recently-viewed/hooks/use-recently-viewed-listings.ts",
          "tooltip": "useRecentlyViewedListings() reads IDs from useRecentlyViewed()"
        },
        {
          "id": "batch-fetch",
          "title": "Fetch Listing Data",
          "method": "GET",
          "layer": "server",
          "status": "built",
          "route": "/api/listings/batch",
          "tooltip": "Only returns active, non-deleted listings. Stale IDs silently filtered. Max 30 IDs.",
          "errorCases": [
            {
              "condition": "No IDs provided",
              "result": "400 Bad Request",
              "httpStatus": 400
            },
            {
              "condition": "More than 30 IDs",
              "result": "400 Bad Request",
              "httpStatus": 400
            }
          ]
        },
        {
          "id": "render-strip",
          "title": "Render Strip",
          "layer": "client",
          "status": "built",
          "codeRef": "src/features/recently-viewed/components/recently-viewed-strip/index.tsx",
          "tooltip": "Horizontal scroll of ListingCards. CSS scroll-snap, 160px mobile / 220px desktop. role=region + aria-label."
        },
        {
          "id": "strip-empty",
          "title": "Render Nothing",
          "layer": "client",
          "status": "built",
          "tooltip": "Strip returns null — no recently viewed items or all stale/deleted"
        }
      ],
      "branches": [
        {
          "afterStep": "batch-fetch",
          "condition": "Listings found?",
          "paths": [
            {
              "label": "Yes",
              "goTo": "render-strip"
            },
            {
              "label": "No",
              "detail": "Empty or all stale/deleted",
              "goTo": "strip-empty"
            }
          ]
        }
      ]
    },
    {
      "id": "clear-history",
      "title": "Clear History",
      "trigger": "User clicks clear recently viewed",
      "steps": [
        {
          "id": "clear-authenticated",
          "title": "Clear from DB",
          "method": "DELETE",
          "layer": "server",
          "status": "built",
          "route": "/api/recently-viewed"
        },
        {
          "id": "clear-guest",
          "title": "Clear localStorage",
          "layer": "background",
          "status": "built",
          "tooltip": "clearRecentlyViewed() — clear localStorage"
        }
      ],
      "branches": [
        {
          "afterStep": "clear-history",
          "condition": "Authenticated?",
          "paths": [
            {
              "label": "Yes",
              "goTo": "clear-authenticated"
            },
            {
              "label": "No",
              "goTo": "clear-guest"
            }
          ]
        }
      ]
    }
  ]
}
