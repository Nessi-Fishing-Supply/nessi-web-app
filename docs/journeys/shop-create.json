{
  "slug": "shop-create",
  "domain": "shops",
  "title": "Create Shop",
  "persona": "shop-owner",
  "description": "User creates a new shop via onboarding, dashboard, or seller opt-in modal. Includes slug generation, availability check, and atomic server-side setup (slug reservation, shop row, owner membership, seller flag).",
  "relatedIssues": [],
  "flows": [
    {
      "id": "create-shop",
      "title": "Shop Creation Flow",
      "trigger": "User navigates to shop creation from onboarding, dashboard, or seller opt-in modal",
      "steps": [
        {
          "id": "entry-point",
          "title": "Open Creation Form",
          "action": "navigate",
          "layer": "client",
          "status": "built",
          "route": "/dashboard/shop/create",
          "tooltip": "Reachable from onboarding, dashboard, or seller opt-in modal"
        },
        {
          "id": "enter-name",
          "title": "Enter Shop Name",
          "action": "type",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "auto-slug",
          "title": "Generate Slug",
          "layer": "client",
          "status": "built",
          "tooltip": "Auto-generate slug from shop name"
        },
        {
          "id": "check-slug",
          "title": "Check Slug Available",
          "layer": "server",
          "status": "built",
          "tooltip": "checkShopSlugAvailable(slug)",
          "errorCases": [
            {
              "condition": "Slug unavailable",
              "result": "Show error, suggest alternatives"
            }
          ]
        },
        {
          "id": "enter-description",
          "title": "Enter Description",
          "action": "type",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "post-shop",
          "title": "Create Shop",
          "method": "POST",
          "layer": "server",
          "status": "built",
          "route": "/api/shops",
          "errorCases": [
            {
              "condition": "Member at 5-shop limit",
              "result": "SHOP_LIMIT_REACHED",
              "httpStatus": 409
            }
          ]
        },
        {
          "id": "reserve-slug",
          "title": "Reserve Slug",
          "layer": "database",
          "status": "built",
          "tooltip": "Reserve slug in slugs table (atomic)"
        },
        {
          "id": "create-shop-row",
          "title": "Create Shop Row",
          "layer": "database",
          "status": "built",
          "tooltip": "Create shop row (owner_id = user)"
        },
        {
          "id": "add-owner-membership",
          "title": "Add Owner Member",
          "layer": "database",
          "status": "built",
          "tooltip": "Add owner to shop_members with owner role"
        },
        {
          "id": "set-seller-flag",
          "title": "Set Seller Flag",
          "layer": "database",
          "status": "built",
          "tooltip": "Set is_seller = true on member"
        },
        {
          "id": "redirect-settings",
          "title": "Open Shop Settings",
          "action": "navigate",
          "layer": "client",
          "status": "built",
          "tooltip": "Redirect to /dashboard/shop/settings"
        }
      ],
      "branches": [
        {
          "afterStep": "check-slug",
          "condition": "Slug available?",
          "paths": [
            {
              "label": "Yes",
              "goTo": "enter-description"
            },
            {
              "label": "No",
              "detail": "Show error, suggest alternatives",
              "goTo": "END"
            }
          ]
        }
      ]
    }
  ]
}
