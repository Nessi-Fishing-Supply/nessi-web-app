{
  "slug": "shop-create",
  "title": "Create Shop",
  "persona": "shop-owner",
  "description": "User creates a new shop via onboarding, dashboard, or seller opt-in modal. Includes slug generation, availability check, and atomic server-side setup (slug reservation, shop row, owner membership, seller flag).",
  "relatedIssues": [],
  "flows": [
    {
      "id": "create-shop",
      "title": "Shop Creation Flow",
      "trigger": "User navigates to shop creation from onboarding, dashboard, or seller opt-in modal",
      "steps": [
        {
          "id": "entry-point",
          "label": "User reaches shop creation form via onboarding, /dashboard/shop/create, or seller opt-in modal",
          "layer": "client",
          "status": "built",
          "route": "/dashboard/shop/create"
        },
        {
          "id": "enter-name",
          "label": "Enter shop name",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "auto-slug",
          "label": "Auto-generate slug from name",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "check-slug",
          "label": "checkShopSlugAvailable(slug)",
          "layer": "server",
          "status": "built",
          "errorCases": [
            { "condition": "Slug unavailable", "result": "Show error, suggest alternatives" }
          ]
        },
        {
          "id": "enter-description",
          "label": "Enter description",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "post-shop",
          "label": "POST /api/shops",
          "layer": "server",
          "status": "built",
          "route": "POST /api/shops",
          "errorCases": [
            {
              "condition": "Member at 5-shop limit",
              "result": "SHOP_LIMIT_REACHED",
              "httpStatus": 409
            }
          ]
        },
        {
          "id": "reserve-slug",
          "label": "Reserve slug in slugs table (atomic)",
          "layer": "database",
          "status": "built"
        },
        {
          "id": "create-shop-row",
          "label": "Create shop row (owner_id = user)",
          "layer": "database",
          "status": "built"
        },
        {
          "id": "add-owner-membership",
          "label": "Add owner to shop_members with owner role",
          "layer": "database",
          "status": "built"
        },
        {
          "id": "set-seller-flag",
          "label": "Set is_seller = true on member",
          "layer": "database",
          "status": "built"
        },
        {
          "id": "redirect-settings",
          "label": "Redirect to /dashboard/shop/settings",
          "layer": "client",
          "status": "built"
        }
      ],
      "branches": [
        {
          "afterStep": "check-slug",
          "condition": "Slug available?",
          "paths": [
            { "label": "Yes", "goTo": "enter-description" },
            { "label": "No — show error", "goTo": "END" }
          ]
        }
      ]
    }
  ]
}
