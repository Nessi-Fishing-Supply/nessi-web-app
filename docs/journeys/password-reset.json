{
  "slug": "password-reset",
  "domain": "auth",
  "title": "Password Reset (3-Step OTP)",
  "persona": "auth",
  "description": "User resets forgotten password via a 3-step flow: enter email, verify OTP code, set new password.",
  "relatedIssues": [],
  "flows": [
    {
      "id": "reset-password",
      "title": "Forgot Password → OTP → New Password",
      "trigger": "User visits /auth/reset-password",
      "steps": [
        {
          "id": "visit-page",
          "title": "Visit Reset Page",
          "action": "navigate",
          "layer": "client",
          "status": "built",
          "route": "/auth/reset-password"
        },
        {
          "id": "enter-email",
          "title": "Enter Email",
          "action": "type",
          "layer": "client",
          "status": "built",
          "tooltip": "Step 1: Enter email address"
        },
        {
          "id": "send-otp",
          "title": "Send Reset OTP",
          "layer": "server",
          "status": "built",
          "tooltip": "forgotPassword(email) — OTP sent to email"
        },
        {
          "id": "enter-otp",
          "title": "Enter OTP Code",
          "action": "type",
          "layer": "client",
          "status": "built",
          "tooltip": "Step 2: Enter 6-digit code from email"
        },
        {
          "id": "verify-otp",
          "title": "Verify OTP",
          "layer": "server",
          "status": "built",
          "tooltip": "verifyOtp(type='recovery')",
          "errorCases": [
            {
              "condition": "Invalid/expired code",
              "result": "Show error, allow retry"
            }
          ]
        },
        {
          "id": "enter-new-password",
          "title": "Enter New Password",
          "action": "type",
          "layer": "client",
          "status": "built",
          "tooltip": "Step 3: Enter new password"
        },
        {
          "id": "reset-password",
          "title": "Reset Password",
          "layer": "server",
          "status": "built",
          "tooltip": "resetPassword(newPassword)"
        },
        {
          "id": "session-established",
          "title": "Set Session",
          "layer": "server",
          "status": "built",
          "tooltip": "Session established via cookies"
        },
        {
          "id": "redirect-home",
          "title": "Redirect Home",
          "action": "navigate",
          "layer": "client",
          "status": "built",
          "tooltip": "Redirect to /"
        }
      ],
      "branches": [
        {
          "afterStep": "verify-otp",
          "condition": "OTP valid?",
          "paths": [
            {
              "label": "Yes",
              "goTo": "enter-new-password"
            },
            {
              "label": "No",
              "detail": "Show error, allow retry",
              "goTo": "enter-otp"
            }
          ]
        }
      ]
    }
  ]
}
