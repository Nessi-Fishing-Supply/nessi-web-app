{
  "slug": "guest-recently-viewed",
  "domain": "shopping",
  "title": "Guest Recently Viewed",
  "persona": "guest",
  "description": "Guest's listing views are tracked in localStorage, deduped and capped at 30 items. On login, views silently merge to the database.",
  "relatedIssues": [],
  "flows": [
    {
      "id": "track-view",
      "title": "Track Listing View",
      "trigger": "Guest views a listing detail page",
      "steps": [
        {
          "id": "view-listing",
          "title": "View Listing Detail",
          "action": "navigate",
          "layer": "client",
          "status": "built"
        },
        {
          "id": "add-recently-viewed",
          "title": "Track View Locally",
          "layer": "background",
          "status": "built",
          "tooltip": "addRecentlyViewed(listingId) called"
        },
        {
          "id": "store-localstorage",
          "title": "Save to localStorage",
          "layer": "background",
          "status": "built"
        },
        {
          "id": "dedup-reorder",
          "title": "Dedup and Reorder",
          "layer": "background",
          "status": "built",
          "tooltip": "Deduped + reordered, max 30 items"
        }
      ]
    },
    {
      "id": "display-strip",
      "title": "Display Recently Viewed Strip",
      "trigger": "Guest visits homepage or category browse page",
      "steps": [
        {
          "id": "hook-reads-localstorage",
          "title": "Read View IDs",
          "layer": "background",
          "status": "built",
          "codeRef": "src/features/recently-viewed/hooks/use-recently-viewed-listings.ts",
          "tooltip": "useRecentlyViewedListings() reads IDs from localStorage via useRecentlyViewed()"
        },
        {
          "id": "batch-fetch",
          "title": "Fetch Listing Data",
          "method": "GET",
          "layer": "server",
          "status": "built",
          "route": "/api/listings/batch",
          "tooltip": "No auth required. Only returns active, non-deleted listings. Stale IDs silently filtered."
        },
        {
          "id": "render-strip",
          "title": "Render Strip",
          "layer": "client",
          "status": "built",
          "codeRef": "src/features/recently-viewed/components/recently-viewed-strip/index.tsx",
          "tooltip": "RecentlyViewedStrip renders horizontal scroll of ListingCards. CSS scroll-snap, 160px mobile / 220px desktop."
        },
        {
          "id": "strip-empty",
          "title": "Render Nothing",
          "layer": "client",
          "status": "built",
          "tooltip": "Strip returns null — no recently viewed items or all stale/deleted"
        }
      ],
      "branches": [
        {
          "afterStep": "batch-fetch",
          "condition": "Listings found?",
          "paths": [
            {
              "label": "Yes",
              "goTo": "render-strip"
            },
            {
              "label": "No",
              "detail": "Empty or all stale/deleted",
              "goTo": "strip-empty"
            }
          ]
        }
      ]
    },
    {
      "id": "merge-on-login",
      "title": "Merge Recently Viewed on Login",
      "trigger": "Guest logs in with items in localStorage recently viewed",
      "steps": [
        {
          "id": "login-detected",
          "title": "Detect Login",
          "layer": "background",
          "status": "built",
          "codeRef": "src/features/recently-viewed/hooks/use-recently-viewed-merge.ts",
          "tooltip": "useRecentlyViewedMerge() detects login"
        },
        {
          "id": "post-merge",
          "title": "Merge Views to DB",
          "method": "POST",
          "layer": "server",
          "status": "built",
          "route": "/api/recently-viewed/merge"
        },
        {
          "id": "merge-to-db",
          "title": "Dedup and Insert",
          "layer": "database",
          "status": "built",
          "tooltip": "Guest views merged to DB, deduped on server"
        },
        {
          "id": "silent-complete",
          "title": "Silent Complete",
          "layer": "background",
          "status": "built",
          "tooltip": "No toast — silent merge"
        }
      ]
    }
  ]
}
