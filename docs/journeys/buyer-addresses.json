{
  "slug": "buyer-addresses",
  "domain": "account",
  "title": "Saved Shipping Addresses",
  "persona": "buyer",
  "description": "Buyer manages up to 5 saved shipping addresses with CRUD operations, default address management, and auto-promotion on delete.",
  "relatedIssues": [],
  "flows": [
    {
      "id": "view-addresses",
      "title": "View Address List",
      "trigger": "Buyer navigates to /dashboard/account → Addresses section",
      "steps": [
        {
          "id": "fetch-addresses",
          "title": "Fetch Addresses",
          "method": "GET",
          "layer": "server",
          "status": "built",
          "route": "/api/addresses"
        },
        {
          "id": "show-list",
          "title": "Show Address Cards",
          "layer": "client",
          "status": "built",
          "tooltip": "AddressList: cards with label, address, default badge"
        }
      ],
      "branches": [
        {
          "afterStep": "fetch-addresses",
          "condition": "Has addresses?",
          "paths": [
            {
              "label": "Yes",
              "goTo": "show-list"
            },
            {
              "label": "No",
              "detail": "Empty state: 'Add your first address'",
              "goTo": "END"
            }
          ]
        }
      ]
    },
    {
      "id": "add-address",
      "title": "Add New Address",
      "trigger": "Buyer clicks 'Add Address'",
      "steps": [
        {
          "id": "check-cap",
          "title": "Check Address Cap",
          "layer": "client",
          "status": "built",
          "tooltip": "Check if at 5-address cap"
        },
        {
          "id": "open-modal",
          "title": "Open Address Form",
          "action": "click",
          "layer": "client",
          "status": "built",
          "tooltip": "AddressFormModal opens"
        },
        {
          "id": "enter-details",
          "title": "Enter Address Details",
          "action": "type",
          "layer": "client",
          "status": "built",
          "tooltip": "Fields: label, line1, line2, city, state, zip, is_default"
        },
        {
          "id": "save-address",
          "title": "Save Address",
          "method": "POST",
          "layer": "server",
          "status": "built",
          "route": "/api/addresses",
          "errorCases": [
            {
              "condition": "Duplicate label",
              "result": "Error: label already used"
            }
          ]
        },
        {
          "id": "list-updates",
          "title": "Refresh List",
          "layer": "client",
          "status": "built",
          "tooltip": "Address saved, list updates"
        }
      ],
      "branches": [
        {
          "afterStep": "check-cap",
          "condition": "At 5-address cap?",
          "paths": [
            {
              "label": "Yes",
              "detail": "Button disabled: maximum reached",
              "goTo": "END"
            },
            {
              "label": "No",
              "goTo": "open-modal"
            }
          ]
        }
      ]
    },
    {
      "id": "manage-addresses",
      "title": "Edit, Delete & Set Default",
      "trigger": "Buyer interacts with address card actions",
      "steps": [
        {
          "id": "edit-address",
          "title": "Edit Address",
          "action": "click",
          "layer": "client",
          "status": "built",
          "tooltip": "AddressFormModal opens pre-populated"
        },
        {
          "id": "delete-address",
          "title": "Delete Address",
          "method": "DELETE",
          "layer": "server",
          "status": "built",
          "route": "/api/addresses/[id]",
          "tooltip": "Confirmation dialog then delete"
        },
        {
          "id": "auto-promote-default",
          "title": "Auto-Promote Default",
          "layer": "server",
          "status": "built",
          "tooltip": "If deleted was default, next address auto-promoted to default"
        },
        {
          "id": "set-default",
          "title": "Set Default Address",
          "method": "PATCH",
          "layer": "server",
          "status": "built",
          "route": "/api/addresses/[id]/default"
        }
      ]
    }
  ]
}
