{
  "slug": "seller-context",
  "domain": "identity",
  "title": "Seller Context (Member vs Shop)",
  "persona": "seller",
  "description": "Listings are created under either member or shop context, controlled by the X-Nessi-Context header. Determines where the listing appears publicly.",
  "relatedIssues": [],
  "flows": [
    {
      "id": "context-assignment",
      "title": "Listing Context Assignment",
      "trigger": "Seller creates a listing",
      "steps": [
        {
          "id": "check-context",
          "title": "Check Active Context",
          "layer": "background",
          "status": "built",
          "tooltip": "Read active context from Zustand store"
        },
        {
          "id": "member-context",
          "title": "Assign to Member",
          "layer": "server",
          "status": "built",
          "tooltip": "seller_id = user.id, member_id = user.id, shop_id = null"
        },
        {
          "id": "shop-context",
          "title": "Assign to Shop",
          "layer": "server",
          "status": "built",
          "tooltip": "seller_id = user.id, member_id = null, shop_id = activeShopId"
        },
        {
          "id": "member-public",
          "title": "Show on Member Page",
          "layer": "client",
          "status": "built",
          "tooltip": "Listing appears on member's public profile at /member/[slug]"
        },
        {
          "id": "shop-public",
          "title": "Show on Shop Page",
          "layer": "client",
          "status": "built",
          "tooltip": "Listing appears on shop's public page at /shop/[slug]"
        }
      ],
      "branches": [
        {
          "afterStep": "check-context",
          "condition": "Active context?",
          "paths": [
            {
              "label": "Member",
              "goTo": "member-context"
            },
            {
              "label": "Shop",
              "goTo": "shop-context"
            }
          ]
        }
      ],
      "connections": [
        {
          "from": "member-context",
          "to": "member-public"
        },
        {
          "from": "shop-context",
          "to": "shop-public"
        }
      ]
    },
    {
      "id": "context-header",
      "title": "X-Nessi-Context Header Validation",
      "trigger": "API request with X-Nessi-Context header",
      "steps": [
        {
          "id": "send-header",
          "title": "Send Context Header",
          "layer": "background",
          "status": "built",
          "tooltip": "X-Nessi-Context header sent with every fetch"
        },
        {
          "id": "validate-member",
          "title": "Validate as Member",
          "layer": "server",
          "status": "built",
          "tooltip": "member — API validates: user owns listing"
        },
        {
          "id": "validate-shop",
          "title": "Validate as Shop",
          "layer": "server",
          "status": "built",
          "tooltip": "shop:{id} — API validates: user is member of shop"
        }
      ],
      "branches": [
        {
          "afterStep": "send-header",
          "condition": "Header value?",
          "paths": [
            {
              "label": "Member",
              "goTo": "validate-member"
            },
            {
              "label": "Shop",
              "goTo": "validate-shop"
            }
          ]
        }
      ]
    }
  ]
}
